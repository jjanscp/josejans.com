---
import { profile } from '~/data/profile';
import { t, type Lang } from '~/data/i18n';

interface Props { lang: Lang; id?: string; }
const { lang, id = 'newsletter' } = Astro.props;

const pubName = profile.newsletter.publicationName[lang];
// Preferred: Substack custom subscribe endpoint (works without iframe)
// Falls back to Buttondown if Substack URL isn't set
const substackUrl = profile.newsletter.substackUrl;
const substackAction = substackUrl ? `${substackUrl}/subscribe` : null;
const buttondownUser = profile.newsletter.buttondownUsername;
const action = substackAction
  ? substackAction
  : buttondownUser
    ? `https://buttondown.com/api/emails/embed-subscribe/${buttondownUser}`
    : null;

const blurb = lang === 'en'
  ? 'One email per new post. No spam, unsubscribe any time.'
  : 'Un correo por entrada. Sin spam, cancela cuando quieras.';

const archiveLabel = lang === 'en' ? 'Read past issues' : 'Leer entradas anteriores';
---
<section id={id} class="newsletter-block newsletter-card">
  <div class="newsletter-inner">
    <div class="newsletter-copy">
      <div class="eyebrow">{lang === 'en' ? 'Newsletter' : 'Boletín'}</div>
      <h3>{pubName}</h3>
      <p>{t.labels.newsletterHeadline[lang]}</p>
      <p class="newsletter-meta">{blurb}</p>
    </div>
    <div class="newsletter-form-wrap">
      {action ? (
        <form
          class="newsletter-form"
          action={action}
          method="post"
          target="_blank"
        >
          <label class="visually-hidden" for={`${id}-email`}>Email</label>
          <input
            id={`${id}-email`}
            type="email"
            name="email"
            placeholder={lang === 'en' ? 'you@example.com' : 'tu@correo.com'}
            required
            autocomplete="email"
          />
          <button class="btn btn-primary" type="submit">{t.labels.newsletterCTA[lang]}</button>
        </form>
      ) : (
        <p class="newsletter-meta">{lang === 'en' ? 'Newsletter coming soon.' : 'Boletín próximamente.'}</p>
      )}
      {substackUrl && (
        <p class="newsletter-meta" style="margin-top: var(--sp-3);">
          <a href={substackUrl} target="_blank" rel="noopener noreferrer">{archiveLabel} →</a>
        </p>
      )}
    </div>
  </div>
</section>
