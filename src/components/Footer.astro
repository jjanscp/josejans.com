---
import { profile } from '~/data/profile';
import { t, type Lang } from '~/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

type Chip = { svg: string; label: string; href: string };

const icons = {
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  twitter: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.7 5.5 4.3 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`,
  github: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>`,
  uic: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="10" width="18" height="11" rx="1"/><path d="M7 10V7a5 5 0 0110 0v3"/><circle cx="12" cy="16" r="2"/></svg>`,
  scholar: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M6 11v5c0 2.76 2.69 5 6 5s6-2.24 6-5v-5"/><path d="M22 8v4"/></svg>`,
  orcid: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M9 7h3a3 3 0 010 6H9V7zm0 6h4m0 0v4"/></svg>`,
  substack: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 5h18M3 10h18M3 19l9-9 9 9V10H3z"/></svg>`,
  doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
};

const chips: (Chip | null)[] = [
  { svg: icons.mail,     label: 'Email',          href: `mailto:${profile.email}` },
  { svg: icons.linkedin, label: 'LinkedIn',        href: profile.social.linkedin },
  { svg: icons.twitter,  label: 'X',               href: profile.social.twitter },
  { svg: icons.instagram,label: 'Instagram',       href: profile.social.instagram },
  profile.social.github  ? { svg: icons.github,   label: 'GitHub',         href: profile.social.github }          : null,
  { svg: icons.uic,      label: 'UIC',             href: profile.social.uic },
  profile.social.scholar ? { svg: icons.scholar,  label: 'Scholar',        href: profile.social.scholar }         : null,
  profile.social.orcid   ? { svg: icons.orcid,    label: 'ORCID',          href: profile.social.orcid }           : null,
  profile.social.substack? { svg: icons.substack, label: 'Substack',       href: profile.social.substack! }       : null,
  profile.social.ssrn    ? { svg: icons.doc,      label: 'SSRN',           href: profile.social.ssrn }            : null,
];
const socialChips = chips.filter(Boolean) as Chip[];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="footer-social">
      {socialChips.map((l) => (
        <a href={l.href} rel="noopener noreferrer" target={l.href.startsWith('mailto') ? '_self' : '_blank'} aria-label={l.label}>
          <span class="icon-sm" aria-hidden="true" set:html={l.svg}></span>
          <span>{l.label}</span>
        </a>
      ))}
    </div>
    <div class="footer-meta">
      &copy; {year} {profile.name} &middot;
      <a href={`/${lang}/cv/`}>{t.labels.downloadCV[lang]}</a> &middot;
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>
