---
import { t, type Lang } from '~/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<section class="section full-bleed">
  <div class="section-inner">
    <div class="section-eyebrow">{t.home.promiseEyebrow[lang]}</div>
    <h2 class="section-title">{t.home.promiseTitle[lang]}</h2>
    <div class="promise-grid">

      <!-- Research -->
      <div class="promise-item">
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
        </svg>
        <h3>{t.home.promiseResearch.title[lang]}</h3>
        <p>{t.home.promiseResearch.body[lang]}</p>
      </div>

      <!-- Advocacy & Consulting -->
      <div class="promise-item">
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 3v17.25m0 0c-1.472-1.657-4.056-2.761-7.125-2.761C3.305 17.489 1.5 17.85 1.5 17.85v-15s1.805-.36 3.375-.36c3.069 0 5.653 1.104 7.125 2.76m0 14.25c1.472-1.656 4.056-2.76 7.125-2.76 1.57 0 3.375.36 3.375.36v15s-1.805-.36-3.375-.36c-3.069 0-5.653-1.104-7.125-2.76"/>
        </svg>
        <h3>{t.home.promiseAdvocacy.title[lang]}</h3>
        <p>{t.home.promiseAdvocacy.body[lang]}</p>
      </div>

      <!-- Teaching -->
      <div class="promise-item">
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
        </svg>
        <h3>{t.home.promiseTeaching.title[lang]}</h3>
        <p>{t.home.promiseTeaching.body[lang]}</p>
      </div>

    </div>
  </div>
</section>
