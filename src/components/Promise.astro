---
import { t, type Lang } from '~/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const slug = {
  research: `/${lang}/research/`,
  advocacy: lang === 'en' ? `/${lang}/advocacy/` : `/${lang}/incidencia/`,
  teaching: `/${lang}/teaching/`,
};
---
<section class="section dark full-bleed">
  <div class="section-inner">
    <div class="section-eyebrow reveal">{t.home.promiseEyebrow[lang]}</div>
    <h2 class="section-title reveal">{t.home.promiseTitle[lang]}</h2>
    <div class="promise-grid reveal-stagger">

      <!-- Investigación -->
      <a class="promise-item promise-link" href={slug.research}>
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
        </svg>
        <h3>{t.home.promiseResearch.title[lang]} <span class="promise-arrow" aria-hidden="true">→</span></h3>
        <p>{t.home.promiseResearch.body[lang]}</p>
      </a>

      <!-- Litigio / Advocacy -->
      <a class="promise-item promise-link" href={slug.advocacy}>
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 6l9-4 9 4v6c0 5-4 9-9 10C7 21 3 17 3 12V6z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <h3>{t.home.promiseAdvocacy.title[lang]} <span class="promise-arrow" aria-hidden="true">→</span></h3>
        <p>{t.home.promiseAdvocacy.body[lang]}</p>
      </a>

      <!-- Docencia -->
      <a class="promise-item promise-link" href={slug.teaching}>
        <svg class="promise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
        </svg>
        <h3>{t.home.promiseTeaching.title[lang]} <span class="promise-arrow" aria-hidden="true">→</span></h3>
        <p>{t.home.promiseTeaching.body[lang]}</p>
      </a>

    </div>
  </div>
</section>

<style>
  .dark .promise-item {
    background: rgba(215,209,161,0.04);
    border-top-color: var(--gold);
  }
  .dark .promise-item:hover {
    background: rgba(215,209,161,0.08);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .dark .promise-icon { color: var(--gold); }
  .dark .promise-item h3 { color: var(--cream-light); }
  .dark .promise-item p  { color: var(--text-on-dark-muted); }
  .promise-link { display: block; text-decoration: none; color: inherit; }
  .promise-link:hover { text-decoration: none; }
  .promise-link:hover h3 { color: var(--gold); }
  .promise-arrow {
    display: inline-block;
    margin-left: 0.25em;
    transition: transform var(--dur-fast);
    color: var(--gold);
  }
  .promise-link:hover .promise-arrow { transform: translateX(4px); }
</style>
