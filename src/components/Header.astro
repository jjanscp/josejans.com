---
import { t, otherLang, type Lang } from '~/data/i18n';
import { profile } from '~/data/profile';

interface Props {
  lang: Lang;
  current?: string;
}
const { lang, current } = Astro.props;

const slug = (lang === 'en')
  ? { about: 'about', research: 'research', advocacy: 'advocacy', teaching: 'teaching', writing: 'writing', contact: 'contact' }
  : { about: 'about', research: 'research', advocacy: 'incidencia', teaching: 'teaching', writing: 'writing', contact: 'contact' };

const navItems = [
  { href: slug.about,    key: 'about' as const },
  { href: slug.research, key: 'research' as const },
  { href: slug.advocacy, key: 'advocacy' as const },
  { href: slug.teaching, key: 'teaching' as const },
  { href: slug.writing,  key: 'writing' as const },
  { href: slug.contact,  key: 'contact' as const },
];

const other = otherLang(lang);
const pathname = Astro.url.pathname;
const switchHref = pathname.replace(`/${lang}/`, `/${other}/`);
---

<header class="site-header">
  <div class="site-header-inner">
    <!-- Home link with icon -->
    <a href={`/${lang}/`} class="site-home-link" aria-label="Home">
      <svg class="site-home-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M3 9.5L10 3l7 6.5V17a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
        <path d="M7 18v-7h6v7"/>
      </svg>
      {profile.shortName}
    </a>

    <!-- Hamburger (mobile only) -->
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Menu"
      type="button"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={`/${lang}/${item.href}/`}
          class={current === item.key ? 'active' : ''}
        >
          {t.nav[item.key][lang]}
        </a>
      ))}

      <!-- Language buttons: EN | ES | FR· | PT· -->
      <div class="lang-toggles" aria-label="Language">
        <a
          href={lang === 'en' ? '#' : switchHref.replace(`/${lang}/`, '/en/')}
          class={`lang-btn ${lang === 'en' ? 'active' : ''}`}
          aria-current={lang === 'en' ? 'true' : undefined}
        >EN</a>
        <a
          href={lang === 'es' ? '#' : switchHref.replace(`/${lang}/`, '/es/')}
          class={`lang-btn ${lang === 'es' ? 'active' : ''}`}
          aria-current={lang === 'es' ? 'true' : undefined}
        >ES</a>
        <a href="/fr/" class="lang-btn">FR</a>
        <a href="/pt/" class="lang-btn">PT</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile hamburger toggle
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.querySelector<HTMLElement>('#site-nav');
  const header = document.querySelector<HTMLElement>('.site-header');
  if (toggle && nav && header) {
    toggle.addEventListener('click', () => {
      const open = header.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Close menu after clicking a link (mobile)
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        header.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
