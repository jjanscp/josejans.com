---
import { t, otherLang, type Lang } from '~/data/i18n';
import { profile } from '~/data/profile';

interface Props {
  lang: Lang;
  current?: string;
}
const { lang, current } = Astro.props;

// Localised slug mapping — advocacy uses a different path in ES ("incidencia").
const slug = (lang === 'en')
  ? { about: 'about', research: 'research', advocacy: 'advocacy', teaching: 'teaching', media: 'media', blog: 'blog', contact: 'contact' }
  : { about: 'about', research: 'research', advocacy: 'incidencia', teaching: 'teaching', media: 'media', blog: 'blog', contact: 'contact' };

const navItems = [
  { href: slug.about,     key: 'about' as const },
  { href: slug.research,  key: 'research' as const },
  { href: slug.advocacy,  key: 'advocacy' as const },
  { href: slug.teaching,  key: 'teaching' as const },
  { href: slug.media,     key: 'media' as const },
  { href: slug.blog,      key: 'blog' as const },
  { href: slug.contact,   key: 'contact' as const },
];

const pathname = Astro.url.pathname;
const other = otherLang(lang);
const switchHref = pathname.replace(`/${lang}/`, `/${other}/`);
---

<header class="site-header">
  <div class="site-header-inner">
    <a href={`/${lang}/`} class="site-title">{profile.shortName}</a>
    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={`/${lang}/${item.href}/`}
          class={current === item.key ? 'active' : ''}
        >
          {t.nav[item.key][lang]}
        </a>
      ))}
      <a href={switchHref} class="lang-toggle" aria-label="Switch language">
        {t.labels.switchLang[lang]}
      </a>
    </nav>
  </div>
</header>
