---
import { profile } from '~/data/profile';
import { t, type Lang } from '~/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<section class="home-hero" id="top">
  <!-- Photo background -->
  <div
    class="hero-bg-img"
    style="background-image: url('/photos/hero-fulbright.jpg');"
    role="img"
    aria-label="José Jans Carretero Pardo at a Fulbright program event"
  ></div>

  <!-- Overlay: starts near-transparent (photo visible); JS darkens on scroll -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Separate bottom fade — always opaque so section transition is smooth -->
  <div class="hero-fade-bottom" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <div class="hero-eyebrow" style="color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,0.5);">{profile.fellowship}</div>

    <h1 class="hero-headline">
      {profile.name.split(' ').slice(0,2).join(' ')}<br>
      <span style="font-weight:500;">{profile.name.split(' ').slice(2).join(' ')}</span>
    </h1>

    <div class="hero-rule" aria-hidden="true"></div>

    <p class="hero-subtitle">{profile.heroSubtitle[lang]}</p>

    <div class="hero-ctas">
      <a class="btn btn-primary" href={`/${lang}/research/`}>
        {lang === 'en' ? 'Research & Publications' : 'Investigación y Publicaciones'}
      </a>
      <a class="btn btn-ghost-light" href={`/${lang}/about/`}>
        {lang === 'en' ? 'About me' : 'Sobre mí'}
      </a>
    </div>
  </div>

  <!-- Scroll cue — sits above the fade-bottom -->
  <div class="hero-scroll-cue" style="z-index:3;" aria-hidden="true">
    <span>{lang === 'en' ? 'Scroll' : 'Desplazar'}</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<script>
  // Scroll-based overlay darkening: photo fully visible at top, dimmed as user scrolls
  const overlay = document.querySelector('.hero-overlay') as HTMLElement | null;
  const hero    = document.querySelector('.home-hero')    as HTMLElement | null;
  if (overlay && hero) {
    const update = () => {
      const progress = Math.min(window.scrollY / (hero.offsetHeight * 0.65), 1);
      // Ease in: opacity 0.22 at top → 1.0 after scrolling 65% of hero height
      overlay.style.opacity = String(0.22 + 0.78 * Math.pow(progress, 0.8));
    };
    window.addEventListener('scroll', update, { passive: true });
    update(); // run on load (scrollY may already be >0 on back-navigation)
  }
</script>
