---
import BaseLayout from '~/layouts/BaseLayout.astro';
import NewsletterEmbed from '~/components/NewsletterEmbed.astro';
import { getCollection } from 'astro:content';
import { fetchSubstackFeed } from '~/lib/substackFeed';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';

const lang = 'en' as const;

const localPosts = (await getCollection('posts', (p: any) => p.data.lang === 'en' && !p.data.draft))
  .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());

const feedUrl = profile.social.substack ? `${profile.social.substack}/feed` : null;
const substackPosts = feedUrl ? await fetchSubstackFeed(feedUrl, 20) : [];

const hasLocal = localPosts.length > 0;
const hasSubstack = substackPosts.length > 0;

const toc = [
  { id: 'overview',   label: 'Overview' },
  { id: 'posts',      label: 'Posts' },
  { id: 'press',      label: 'Press' },
  { id: 'newsletter', label: 'Newsletter' },
];
---
<BaseLayout
  title="Writing & Media"
  description={`Blog, opinion pieces, and press appearances by ${profile.name}.`}
  lang={lang}
  current="writing"
  toc={toc}
>
  <!-- Header -->
  <section class="section" id="overview">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">{t.nav.writing[lang]}</div>
      <h1 class="section-title">Opinion &amp; Media</h1>
      <p class="lead">Public scholarship, op-eds, and press commentary.</p>
      <p class="section-body">
        Short essays, research notes, and commentary on transitional justice, Colombian politics,
        courts, and social movements — published via
        <a href={profile.social.substack} target="_blank" rel="noopener noreferrer">Substack</a>.
        For press inquiries write to <a href={`mailto:${profile.email}`}>{profile.email}</a>.
      </p>
    </div>
  </section>

  <!-- Inline radio-interview photo (natural aspect, centered) -->
  <section class="section">
    <figure class="photo-inline reveal-fade">
      <img
        src="/photos/media-radio.jpg"
        alt="Radio interview — Banco del Parque Radio, Colombia"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Radio · Banco del Parque Radio · Colombia</figcaption>
    </figure>
  </section>

  <!-- Blog posts (Substack feed) -->
  {(hasLocal || hasSubstack) ? (
    <section class="section full-bleed" id="posts">
      <div class="section-inner reveal">
        <h2 class="section-title">{profile.newsletter.publicationName[lang]}</h2>
        <ul class="post-list">
          {hasLocal && localPosts.map((p: any) => (
            <li>
              <time datetime={p.data.date.toISOString()}>
                {p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3><a href={`/${lang}/blog/${p.id.replace(/\.(md|mdx)$/, '')}/`}>{p.data.title}</a></h3>
              {p.data.summary && <p class="muted">{p.data.summary}</p>}
            </li>
          ))}
          {hasSubstack && substackPosts.map((p) => (
            <li>
              <time datetime={p.published.toISOString()}>
                {p.published.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3><a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a></h3>
              {p.summary && <p class="muted">{p.summary}</p>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : (
    <section class="section" id="posts">
      <div class="section-inner" style="max-width: var(--measure);">
        <p class="muted">{t.labels.noPostsYet[lang]}</p>
      </div>
    </section>
  )}

  <!-- Op-eds & Press -->
  <section class="section" id="press">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">Op-eds &amp; press appearances</h2>
      <p class="muted">
        Op-eds, media appearances, and interviews will be listed here as they are published.
        Follow <a href={profile.social.twitter} target="_blank" rel="noopener noreferrer">X / Twitter</a> for real-time commentary.
      </p>
      <!--
        TO ADD AN ITEM — format:
        <li style="border-left: 2px solid var(--rule); padding-left: var(--sp-4); margin-bottom: var(--sp-4);">
          <div style="font-size:.78rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;">Month YYYY · Outlet</div>
          <div style="font-family:var(--font-serif);font-size:1.05rem;"><a href="URL">Title of piece</a></div>
        </li>
      -->
    </div>
  </section>

  <!-- Newsletter subscribe -->
  <section class="section full-bleed" id="newsletter">
    <div class="section-inner reveal">
      <NewsletterEmbed lang={lang} />
    </div>
  </section>
</BaseLayout>
