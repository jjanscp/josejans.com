---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactInline from '~/components/ContactInline.astro';
import PageNav from '~/components/PageNav.astro';
import { profile } from '~/data/profile';
import { bio } from '~/data/bio';

const lang = 'en' as const;

const navItems = [
  { id: 'about',        label: 'About' },
  { id: 'research',     label: 'Research' },
  { id: 'professional', label: 'Practice' },
  { id: 'teaching',     label: 'Teaching' },
  { id: 'personal',     label: 'Beyond the work' },
  { id: 'education',    label: 'Education' },
  { id: 'contact',      label: 'Contact' },
];
---
<BaseLayout
  title="About"
  description={`About ${profile.name} — PhD student in Political Science at UIC, Fulbright–MinCiencias Scholar, former Lead Counsel at the JEP and senior attorney at CAJAR.`}
  lang={lang}
  current="about"
>
  <PageNav items={navItems} label="Contents" />

  <!-- No full-bleed cropping hero. Photos live inline at natural aspect within each section. -->

  <!-- About: split layout — headshot left, bio right -->
  <section class="section" id="about">
    <div class="section-inner">
      <div class="about-split">
        <!-- Photo column -->
        <div class="photo-col reveal">
          <img
            class="photo-profile"
            src="/photos/headshot.jpg"
            alt="José Jans Carretero Pardo"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Text column -->
        <div class="reveal">
          <div class="section-eyebrow">PhD Student · Fulbright Scholar</div>
          <h1 class="section-title">{profile.name}</h1>
          <p class="lead">{profile.title[lang]} &middot; {profile.affiliation[lang]}</p>
          <div style="margin-top: var(--sp-5);" class="prose" set:html={bio.short[lang]} />
          <div style="margin-top: var(--sp-5); display:flex; gap: var(--sp-3); flex-wrap: wrap;">
            <a class="btn btn-primary" href={`/${lang}/research/`}>Research &amp; Publications</a>
            <a class="btn btn-outline" href="/cv.pdf" target="_blank" rel="noopener">Download CV</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research agenda -->
  <section class="section dark full-bleed" id="research">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="section-eyebrow reveal">Research agenda</div>
      <h2 class="section-title reveal">The research agenda</h2>
      <div class="lead prose reveal" set:html={bio.research[lang]} />
      <div style="margin-top: var(--sp-6);" class="reveal">
        <h3 style="color: var(--cream-light); font-size: 1rem; margin-bottom: var(--sp-3); font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.72rem;">Research interests</h3>
        <ul class="interest-list dark-list reveal-stagger">
          {bio.interests[lang].map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Professional arc + JEP portrait -->
  <section class="section" id="professional">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="photo-split reveal">
        <img
          src="/photos/portrait-jep.jpg"
          alt="José Jans Carretero Pardo at the Special Jurisdiction for Peace (JEP), Bogotá"
          loading="lazy"
          decoding="async"
        />
        <div>
          <div class="section-eyebrow">2015–2024 · Colombia</div>
          <h2 class="section-title">A decade of frontline practice</h2>
          <div class="section-body prose" set:html={bio.professional[lang]} />
          <p style="margin-top: var(--sp-4);">
            <a class="btn btn-outline" href={`/${lang}/advocacy/`}>Full advocacy portfolio →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ICC assembly inline photo -->
  <section class="section">
    <figure class="photo-inline reveal-fade">
      <img
        src="/photos/icc-assembly.jpg"
        alt="José Jans Carretero Pardo at the ICC Assembly of States Parties, The Hague"
        loading="lazy"
        decoding="async"
      />
      <figcaption>ICC Assembly of States Parties · The Hague · 2019</figcaption>
    </figure>
  </section>

  <!-- Teaching arc — clinic photo lives on the Teaching page; teaser text here -->
  <section class="section full-bleed" style="background: var(--bg-subtle);" id="teaching">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Legal education · Colombia</div>
      <h2 class="section-title">Teaching and clinical work</h2>
      <div class="section-body prose" set:html={bio.teaching[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="btn btn-outline" href={`/${lang}/teaching/`}>Teaching portfolio →</a>
      </p>
    </div>
  </section>

  <!-- Personal -->
  <section class="section" id="personal">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Beyond the work</div>
      <h2 class="section-title">A bit more about me</h2>
      <div class="section-body prose" set:html={bio.personal[lang]} />
    </div>
    <!-- Ironman inline photo at natural aspect -->
    <figure class="photo-inline reveal-fade">
      <img
        src="/photos/personal-ironman.jpg"
        alt="Ironman 70.3 Cartagena Colombia — finish line"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Ironman 70.3 Cartagena · Colombia</figcaption>
    </figure>
  </section>

  <!-- Education & formation -->
  <section class="section dark full-bleed" id="education">
    <div class="section-inner" style="max-width: var(--measure);">
      <h2 class="section-title reveal">Education</h2>
      <ul class="edu-list reveal-stagger">
        {bio.education[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 class="reveal" style="font-size:1rem; margin-top: var(--sp-6); margin-bottom: var(--sp-3); color: var(--cream); font-family: var(--font-sans); text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem;">Additional training</h3>
      <ul class="edu-list reveal-stagger">
        {bio.training[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 class="reveal" style="font-size:1rem; margin-top: var(--sp-6); margin-bottom: var(--sp-3); color: var(--cream); font-family: var(--font-sans); text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem;">Affiliations</h3>
      <ul class="edu-list reveal-stagger">
        {bio.affiliations[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <p class="reveal" style="margin-top: var(--sp-3); color: var(--text-on-dark-muted);">
        Languages: {bio.languages[lang]}
      </p>

      <p style="margin-top: var(--sp-6);" class="reveal">
        <a class="btn btn-ghost-light" href="/cv.pdf" target="_blank" rel="noopener">Download full CV (PDF)</a>
      </p>
    </div>
  </section>

  <!-- Contact -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .dark-list li { color: var(--text-on-dark-muted); }
  .dark-list li::before { color: var(--gold); }
  .about-split .photo-col { align-self: start; }
</style>
