---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Avatar from '~/components/Avatar.astro';
import ImagePlaceholder from '~/components/ImagePlaceholder.astro';
import ContactInline from '~/components/ContactInline.astro';
import { profile } from '~/data/profile';
import { bio } from '~/data/bio';

const lang = 'en' as const;
---
<BaseLayout
  title="About"
  description={`About ${profile.name} — PhD student in Political Science at UIC, Fulbright–MinCiencias Scholar, former Lead Counsel at the JEP and senior attorney at CAJAR.`}
  lang={lang}
  current="about"
>
  <!-- Page header -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">About</div>
      <h1 class="section-title">{profile.name}</h1>
      <p class="lead">{profile.title[lang]} &middot; {profile.affiliation[lang]}</p>
    </div>
  </section>

  <!-- Portrait placeholder -->
  <section class="section full-bleed" style="padding-block: 0;">
    <ImagePlaceholder
      kind="landscape"
      emoji="📷"
      desc="Full-width about photo — in the field, at court, or teaching"
      spec="2400×900 JPG · dark or neutral background preferred"
    />
  </section>

  <!-- Block 1: Academic + doctoral arc -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">PhD Student · Fulbright Scholar</div>
      <h2 class="section-title">The research agenda</h2>
      <div class="section-body prose" set:html={bio.research[lang]} />
      <h3 style="margin-top: var(--sp-6);">Research interests</h3>
      <ul class="interest-list">
        {bio.interests[lang].map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- Block 2: Professional / practice arc -->
  <section class="section full-bleed">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">2015–2024 · Colombia</div>
      <h2 class="section-title">A decade of frontline practice</h2>
      <div class="section-body prose" set:html={bio.professional[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="section-cta" href={`/${lang}/advocacy/`}>
          See the full advocacy portfolio →
        </a>
      </p>
    </div>
  </section>

  <!-- Block 3: Teaching arc -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Legal education · Colombia</div>
      <h2 class="section-title">Teaching and clinical work</h2>
      <div class="section-body prose" set:html={bio.teaching[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="section-cta" href={`/${lang}/teaching/`}>
          Teaching portfolio →
        </a>
      </p>
      <!-- Classroom placeholder -->
      <div style="margin-top: var(--sp-6);">
        <ImagePlaceholder
          kind="landscape"
          emoji="🏛️"
          desc="Classroom or clinic photo — UIS or Uniandes seminar"
          spec="1200×600 JPG"
        />
      </div>
    </div>
  </section>

  <!-- Block 4: Personal story -->
  <section class="section full-bleed">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Beyond the work</div>
      <h2 class="section-title">A bit more about me</h2>
      <div class="section-body prose" set:html={bio.personal[lang]} />
    </div>
  </section>

  <!-- Block 5: Education + formation -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <h2 class="section-title">Education</h2>
      <ul class="cv-list">
        {bio.education[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Additional training</h3>
      <ul class="cv-list">
        {bio.training[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Affiliations</h3>
      <ul class="cv-list">
        {bio.affiliations[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Languages</h3>
      <p>{bio.languages[lang]}</p>

      <p style="margin-top: var(--sp-6);">
        <a class="btn btn-outline" href="/cv.pdf" target="_blank" rel="noopener">Download full CV (PDF)</a>
      </p>
    </div>
  </section>

  <!-- Contact inline -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .interest-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .interest-list li {
    padding-left: var(--sp-4);
    position: relative;
  }
  .interest-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-sans);
  }
  .cv-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .cv-list li {
    border-left: 3px solid var(--rule);
    padding-left: var(--sp-4);
    line-height: 1.65;
  }
  .prose {
    line-height: 1.75;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
</style>
