---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';

const socialLinks = [
  { label: 'Email', href: `mailto:${profile.email}`, val: profile.email },
  { label: 'LinkedIn', href: profile.social.linkedin, val: 'linkedin.com/in/josejans' },
  { label: 'X / Twitter', href: profile.social.twitter, val: '@josejanscp' },
  { label: 'GitHub', href: profile.social.github, val: 'github.com/josejanscp' },
  { label: 'UIC Department', href: profile.social.uic, val: 'pols.uic.edu' },
  profile.social.scholar && { label: 'Google Scholar', href: profile.social.scholar, val: 'scholar.google.com/citations' },
  profile.social.orcid && { label: 'ORCID', href: profile.social.orcid, val: 'orcid.org' },
  profile.social.ssrn && { label: 'SSRN', href: profile.social.ssrn, val: 'ssrn.com' },
  profile.social.researchgate && { label: 'ResearchGate', href: profile.social.researchgate, val: 'researchgate.net/profile/Jose-Carretero-5' },
  profile.social.academia && { label: 'Academia.edu', href: profile.social.academia, val: 'uniandes.academia.edu/josejanscarreteropardo' },
].filter(Boolean) as { label: string; href: string; val: string }[];

const toc = [
  { id: 'overview',   label: 'Overview' },
  { id: 'profiles',   label: 'Profiles' },
  { id: 'newsletter', label: 'Newsletter' },
];
---
<BaseLayout title="Contact" lang="en" current="contact" toc={toc}>

  <!-- Hero CTA -->
  <section class="section" id="overview">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Contact</div>
      <h1 class="section-title">Let&rsquo;s talk.</h1>
      <p class="lead">
        Research collaborations, consulting briefs, expert testimony, speaking invitations, or press inquiries — this inbox is open.
      </p>
      <p class="section-body" style="margin-bottom: var(--sp-5);">
        You can also reach me directly at <a href={`mailto:${profile.email}`}>{profile.email}</a>.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
        action="/en/thanks/"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
        <label>
          <span>{t.labels.yourName.en}</span>
          <input type="text" name="name" required autocomplete="name" placeholder="Your name" />
        </label>
        <label>
          <span>{t.labels.yourEmail.en}</span>
          <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" />
        </label>
        <label class="full-width">
          <span>{t.labels.yourMessage.en}</span>
          <textarea name="message" rows="6" required placeholder="Tell me about your project, question, or invitation..."></textarea>
        </label>
        <button type="submit" class="btn btn-accent full-width">{t.labels.contactSend.en} →</button>
      </form>
    </div>
  </section>

  <!-- Profiles -->
  <section class="section full-bleed" id="profiles">
    <div class="section-inner reveal">
      <h2 class="section-title">Professional &amp; academic profiles</h2>
      <ul class="profile-list">
        {socialLinks.map((l) => (
          <li>
            <span class="profile-label">{l.label}</span>
            <a href={l.href} target={l.href.startsWith('mailto') ? '_self' : '_blank'} rel="noopener noreferrer">{l.val}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section" id="newsletter">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Newsletter</div>
      <h2 class="section-title" style="font-size: 1.6rem;">Research updates, a few times a year.</h2>
      <p class="section-body">{t.labels.newsletterHeadline.en}</p>
      {profile.newsletter.username ? (
        <form
          action={`https://buttondown.com/api/emails/embed-subscribe/${profile.newsletter.username}`}
          method="post"
          target="popupwindow"
          onsubmit={`window.open('https://buttondown.com/${profile.newsletter.username}', 'popupwindow')`}
          class="newsletter-inline-form"
          style="margin-top: var(--sp-4);"
        >
          <input type="email" name="email" placeholder="you@example.com" required />
          <button type="submit" class="btn btn-accent">{t.labels.newsletterCTA.en}</button>
        </form>
      ) : (
        <p class="muted small" style="margin-top: var(--sp-3);">Newsletter signup coming soon.</p>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .contact-form label span {
    font-size: 0.8rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
  }
  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: transparent;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: var(--accent);
  }
  .contact-form .full-width {
    grid-column: 1 / -1;
  }
  .contact-form button.full-width {
    grid-column: 1 / -1;
    justify-self: start;
  }
  @media (max-width: 600px) {
    .contact-form {
      grid-template-columns: 1fr;
    }
  }

  .profile-list {
    list-style: none;
    margin: var(--sp-4) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--sp-3);
  }
  .profile-list li {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--rule);
    border-radius: 8px;
    transition: border-color 0.2s;
  }
  .profile-list li:hover {
    border-color: var(--accent);
  }
  .profile-label {
    font-size: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .profile-list a {
    font-size: 0.9rem;
    word-break: break-all;
  }

  .newsletter-inline-form {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .newsletter-inline-form input[type="email"] {
    flex: 1;
    min-width: 200px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: transparent;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-inline-form input[type="email"]:focus {
    border-color: var(--accent);
  }
</style>
