---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomeHero from '~/components/HomeHero.astro';
import Promise from '~/components/Promise.astro';
import SectionTease from '~/components/SectionTease.astro';
import SocialRow from '~/components/SocialRow.astro';
import NewsletterEmbed from '~/components/NewsletterEmbed.astro';
import ContactInline from '~/components/ContactInline.astro';
import { getCollection } from 'astro:content';
import { fetchSubstackFeed } from '~/lib/substackFeed';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';

const lang = 'en' as const;

// Fetch latest posts for home preview
const localPosts = (await getCollection('posts', (p: any) => p.data.lang === 'en' && !p.data.draft))
  .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const feedUrl = profile.social.substack ? `${profile.social.substack}/feed` : null;
const substackRaw = feedUrl ? (await fetchSubstackFeed(feedUrl, 3)) : [];

// Merge local + Substack, take top 3 by date
const latestPosts = [
  ...localPosts.map((p: any) => ({
    date: p.data.date as Date,
    title: p.data.title as string,
    summary: (p.data.summary ?? '') as string,
    href: `/${lang}/blog/${p.id.replace(/\.(md|mdx)$/, '')}/`,
    external: false,
  })),
  ...substackRaw.map((p) => ({
    date: p.published,
    title: p.title,
    summary: p.summary ?? '',
    href: p.url,
    external: true,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 3);

// Featured tease items for Research section
const researchItems = [
  {
    year: 2021,
    meta: "IdeAs \u2014 Id\u00e9es d'Am\u00e9riques",
    title: 'Disputed fields in the protection of social leaders in Colombia',
    href: 'https://journals.openedition.org/ideas/10381?lang=en',
  },
  {
    year: 2020,
    meta: 'FIDH & CAJAR Report',
    title: 'Colombia at Risk of Impunity: Blind spots of transitional justice regarding international crimes',
  },
  {
    year: 2018,
    meta: 'Book chapter \u2014 Universidad Libre',
    title: "From the Havana talks to the Colombian Congress: Where were the victims\u2019 rights?",
  },
];

// Featured tease items for Advocacy section
const advocacyItems = [
  {
    year: '2019\u20132020',
    meta: 'Constitutional Court',
    title: "Victims\u2019 rights in the JEP Procedure Law \u2014 C-590/2019, C-050/2020",
  },
  {
    year: '2022\u20132023',
    meta: 'Constitutional Court',
    title: 'Freedom of speech & Indigenous rights \u2014 T-087/2023, SU-545/2023, SU-546/2023',
  },
  {
    year: 2018,
    meta: 'Council of State',
    title: 'Drug policy as a public health matter \u2014 201800444',
  },
];

const toc = [
  { id: 'overview', label: 'Overview' },
  { id: 'explore',  label: 'Explore' },
  { id: 'research', label: 'Research' },
  { id: 'advocacy', label: 'Litigation' },
  { id: 'teaching', label: 'Teaching' },
  { id: 'writing',  label: 'Writing' },
  { id: 'contact',  label: 'Contact' },
];

// Featured tease items for Teaching
const teachingItems = [
  {
    meta: 'UIS Legal Clinic',
    title: 'Founding Coordinator \u2014 Carlos Gaviria D\u00edaz Strategic Litigation Legal Clinic',
  },
  {
    meta: "UIS Master\u2019s Program",
    title: 'Research Methodologies in Human Rights',
  },
  {
    meta: 'Universidad de los Andes',
    title: 'TA & RA fellowships \u00b7 Centre for Sociolegal Research (CIJUS)',
  },
];
---
<BaseLayout
  title={profile.name}
  description={`${profile.name} — PhD student in Political Science at UIC, Fulbright–MinCiencias Scholar. Research on transitional justice, courts, and rights mobilization.`}
  lang={lang}
  current="home"
  toc={toc}
>
  <!-- 1. Hero -->
  <div id="overview">
    <HomeHero lang={lang} />
  </div>

  <!-- 2. What I do (Promise) -->
  <Promise lang={lang} />

  <!-- 3. Short bio -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <p class="lead" set:html={bio.short[lang]} />
    </div>
  </section>

  <!-- 4. Explore — grid of section shortcuts -->
  <section class="section" id="explore">
    <div class="section-inner">
      <div class="section-eyebrow reveal">Explore the site</div>
      <h2 class="section-title reveal" style="margin-bottom: var(--sp-5);">Where to next?</h2>
      <div class="explore-grid reveal-stagger">
        <a class="explore-card" href={`/${lang}/research/`}>
          <div class="explore-eyebrow">01</div>
          <h3>Research &amp; Publications</h3>
          <p>Peer-reviewed articles, book chapters, policy reports, and works in progress.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/advocacy/`}>
          <div class="explore-eyebrow">02</div>
          <h3>Litigation</h3>
          <p>Thirty-plus amicus curiae briefs and constitutional interventions before Colombian high courts, the Inter-American system, and the ICC.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/teaching/`}>
          <div class="explore-eyebrow">03</div>
          <h3>Teaching</h3>
          <p>Constitutional Theory, Research Methods, and clinical legal education at UIS and Universidad de los Andes.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/writing/`}>
          <div class="explore-eyebrow">04</div>
          <h3>Opinion &amp; Media</h3>
          <p>Op-eds, press appearances, radio, and podcasts on transitional justice and human rights.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/cv/`}>
          <div class="explore-eyebrow">05</div>
          <h3>Curriculum Vitae</h3>
          <p>Full academic CV — education, grants, research experience, publications, and service.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/contact/`}>
          <div class="explore-eyebrow">06</div>
          <h3>Contact</h3>
          <p>Research collaborations, consulting briefs, expert testimony, speaking invitations, or press inquiries.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Research & Publications tease -->
  <div id="research">
    <SectionTease
      lang={lang}
      eyebrow={t.home.researchEyebrow[lang]}
      title="Peer-reviewed articles, policy reports, and research datasets."
      body={t.home.researchBody[lang]}
      href={`/${lang}/research/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={researchItems}
      variant="subtle"
    />
  </div>

  <!-- 6. Advocacy & Consulting tease -->
  <div id="advocacy">
    <SectionTease
      lang={lang}
      eyebrow={t.home.advocacyEyebrow[lang]}
      title="Thirty-plus amicus curiae briefs and constitutional interventions."
      body={t.home.advocacyBody[lang]}
      href={`/${lang}/advocacy/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={advocacyItems}
      variant="light"
    />
  </div>

  <!-- 7. Teaching tease -->
  <div id="teaching">
    <SectionTease
      lang={lang}
      eyebrow={t.home.teachingEyebrow[lang]}
      title="Clinical, constitutional, and methodological teaching."
      body={t.home.teachingBody[lang]}
      href={`/${lang}/teaching/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={teachingItems}
      variant="subtle"
    />
  </div>

  <!-- 8. Writing & Newsletter (merged single section) -->
  <section class="section full-bleed" id="writing">
    <div class="section-inner">
      <div class="section-eyebrow">{t.nav.writing[lang]}</div>
      <h2 class="section-title">{profile.newsletter.publicationName[lang]}</h2>
      {latestPosts.length > 0 ? (
        <ul class="post-list home-post-list">
          {latestPosts.map((p) => (
            <li>
              <time datetime={p.date.toISOString()}>
                {p.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3>
                <a href={p.href} {...(p.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  {p.title}
                </a>
              </h3>
              {p.summary && <p class="muted">{p.summary}</p>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="muted">{t.labels.noPostsYet[lang]}</p>
      )}
      <p style="margin-top: var(--sp-5);">
        <a class="btn btn-outline" href={`/${lang}/writing/`}>All writing &amp; press &rarr;</a>
      </p>
      <div style="margin-top: var(--sp-8); padding-top: var(--sp-6); border-top: 1px solid var(--rule);">
        <NewsletterEmbed lang={lang} />
      </div>
    </div>
  </section>

  <!-- 9. Social row -->
  <section class="section">
    <div class="section-inner">
      <div class="section-eyebrow">Find me online</div>
      <SocialRow lang={lang} />
    </div>
  </section>

  <!-- 10. Contact -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .cta-strip { padding-block: var(--sp-2); }
  .cta-strip-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }
  .home-post-list {
    margin-top: var(--sp-5);
  }
</style>
