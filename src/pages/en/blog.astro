---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', (p: any) => p.data.lang === 'en' && !p.data.draft))
  .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Blog" lang="en" current="blog">
  <h1>Blog &amp; News</h1>

  <p>
    Short-form writing on my ongoing research, teaching, and fieldwork — plus occasional
    commentary on Colombian politics, transitional justice, and the courts.
  </p>

  {posts.length === 0 ? (
    <p class="muted">No posts yet. Check back soon, or <a href="/en/contact/#newsletter">subscribe</a> to get updates.</p>
  ) : (
    <ul class="post-list">
      {posts.map((p: any) => (
        <li>
          <time datetime={p.data.date.toISOString()}>{p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <h2><a href={`/en/blog/${p.id.replace(/\.(md|mdx)$/, '')}/`}>{p.data.title}</a></h2>
          {p.data.summary && <p>{p.data.summary}</p>}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
