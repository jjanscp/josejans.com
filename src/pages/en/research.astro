---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';
import { profile } from '~/data/profile';

const lang = 'en' as const;

const all = (await getCollection('publications', (p: any) => p.data.lang === 'en' || !p.data.lang))
  .sort((a: any, b: any) => b.data.year - a.data.year);

const articles    = all.filter((p: any) => p.data.type === 'article');
const chapters    = all.filter((p: any) => p.data.type === 'chapter');
const reports     = all.filter((p: any) => p.data.type === 'report');
const wip         = all.filter((p: any) => p.data.type === 'wip');

// Hard-coded publications (from CV) until CMS entries exist
const staticArticles = [
  {
    authors: 'Carretero Pardo, J. J., & Ochoa Sterling, T.',
    year: 2021,
    title: 'Disputed fields in the protection of social leaders in Colombia',
    venue: 'IdeAs — Idées d\'Amériques',
    volume: '17',
    url: 'https://journals.openedition.org/ideas/10381?lang=en',
    doi: '10.4000/ideas.10381',
    abstract: 'Analyzes the protection of social leaders through the lens of transnational human-rights networks and the Colombian transitional justice framework.',
    tags: ['social leaders', 'transitional justice', 'human rights', 'Colombia'],
    lang: ['en', 'fr'],
  },
];

const staticChapters = [
  {
    authors: 'Carretero Pardo, J. J., & Rodríguez, C.',
    year: 2018,
    title: 'From the Havana talks to the Colombian Congress: Where were the victims\u2019 rights in the implementation of the Final Peace Agreement?',
    venue: 'Discussions on the implementation of the final peace agreement between the Government of Colombia and the FARC-EP',
    publisher: 'Universidad Libre',
    abstract: 'Examines victims\u2019 rights provisions in the legislative implementation of the 2016 Colombian Peace Agreement.',
    tags: ['victims\u2019 rights', 'peace agreement', 'Colombia', 'transitional justice'],
  },
];

const staticReports = [
  {
    authors: 'FIDH & CAJAR (Carretero Pardo, J. J., principal drafter)',
    year: 2020,
    title: 'Colombia at Risk of Impunity: Blind spots of transitional justice regarding international crimes under ICC jurisdiction',
    tags: ['transitional justice', 'ICC', 'impunity', 'Colombia'],
    cover: '/covers/cover-fidh-2020.jpg',
  },
  {
    authors: 'CSPP et al. (Carretero Pardo, J. J., co-author)',
    year: 2020,
    title: 'Dismantling Paramilitarism: Proposal for public policy guidelines',
    tags: ['paramilitarism', 'policy', 'Colombia'],
    cover: '/covers/cover-desmantel-2020.jpg',
  },
  {
    authors: 'CAJAR (Carretero Pardo, J. J., contributor)',
    year: 2019,
    title: 'Web of Impunity: Voices of resilience against state and paramilitary violence in Magdalena Medio (1998–2000)',
    tags: ['impunity', 'human rights', 'Colombia'],
    cover: '/covers/cover-telaranas-2019.jpg',
  },
  {
    authors: 'CAJAR (Carretero Pardo, J. J., contributor)',
    year: 2019,
    title: 'The true story of the Wiwa people, from the heart of the world, in the context of the internal armed conflict (1990–2017)',
    tags: ['indigenous rights', 'armed conflict', 'Colombia'],
    cover: '/covers/cover-wiwa-2019.jpg',
  },
];

// Book chapter covers (attach by year+publisher when no CMS entry exists)
const chapterCovers: Record<string, string> = {
  '2018-Universidad Libre': '/covers/cover-libre-2018.jpg',
};

// Merge CMS + static (CMS entries take precedence if they exist)
const showArticles  = articles.length  > 0 ? articles  : staticArticles;
const showChapters  = chapters.length  > 0 ? chapters  : staticChapters;
const showReports   = reports.length   > 0 ? reports   : staticReports;

// Helper: handle authors as string OR array
const authStr = (a: string | string[] | undefined): string =>
  Array.isArray(a) ? a.join(', ') : (a ?? '');

const toc = [
  { id: 'agenda',    label: 'Agenda' },
  { id: 'interests', label: 'Interests' },
  { id: 'wip',       label: 'Works in progress' },
  { id: 'articles',  label: 'Articles' },
  { id: 'chapters',  label: 'Chapters' },
  { id: 'reports',   label: 'Reports' },
  { id: 'datasets',  label: 'Datasets' },
  { id: 'interventions', label: 'Interventions' },
  { id: 'experience', label: 'Experience' },
];
---
<BaseLayout
  title="Research & Publications"
  description="Research agenda, peer-reviewed articles, book chapters, policy reports, and datasets by José Jans Carretero Pardo on transitional justice, courts, and rights mobilization."
  lang={lang}
  current="research"
  toc={toc}
>
  <!-- Hero photo -->
  <SectionHero
    src="/photos/advocacy-memorial.jpg"
    alt="Human rights memorial vigil, Plaza de Bolívar, Bogotá"
    caption="¡Más vivos que nunca! · Human rights memorial · Plaza de Bolívar, Bogotá"
    position="center 40%"
  />

  <!-- Header + full research agenda (pillars) -->
  <section class="section dark full-bleed" id="agenda">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="section-eyebrow reveal">Research agenda</div>
      <h1 class="section-title reveal">The research agenda</h1>
      <div class="reveal" set:html={bio.research[lang]} />
    </div>
  </section>

  <!-- Works in progress (from bio.wip — bilingual data) -->
  <section class="section" id="wip">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.wip[lang]}</h2>
      {wip.length > 0 ? (
        <ul class="pub-list">
          {wip.map((p: any) => (
            <li class="wip-slot">
              <span class="badge wip">{p.data.status || t.labels.inPreparation[lang]}</span>
              <div class="pub-title">{p.data.title}</div>
              <div class="pub-meta muted">{p.data.authors?.join(', ')} · {p.data.year}</div>
              {p.data.abstract && (
                <details class="pub-abstract"><summary>{t.labels.abstract[lang]}</summary><p>{p.data.abstract}</p></details>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <ul class="pub-list wip-list">
          {bio.wip.map((p) => (
            <li class="wip-slot">
              <span class="badge wip">{p.status[lang]}</span>
              <div class="pub-title">{p.title[lang]}</div>
              <div class="pub-meta muted">{p.authors[lang]}</div>
              <details class="pub-abstract">
                <summary>{t.labels.abstract[lang]}</summary>
                <p>{p.abstract[lang]}</p>
              </details>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- Peer-reviewed articles -->
  <section class="section full-bleed" id="articles">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.peerReviewed[lang]}</h2>
      <ul class="pub-list rich">
        {showArticles.map((p: any) => (
          <li>
            <div class="pub-meta muted">{p.data?.year ?? p.year} &middot; {p.data?.venue ?? p.venue}{p.data?.volume ?? p.volume ? `, ${p.data?.volume ?? p.volume}` : ''}</div>
            <div class="pub-title">
              {(p.data?.url ?? p.url)
                ? <a href={p.data?.url ?? p.url} target="_blank" rel="noopener noreferrer">{p.data?.title ?? p.title}</a>
                : (p.data?.title ?? p.title)}
            </div>
            <div class="pub-authors muted">{authStr(p.data?.authors ?? p.authors)}</div>
            {(p.data?.doi ?? p.doi) && (
              <div class="pub-links">
                <a href={`https://doi.org/${p.data?.doi ?? p.doi}`} target="_blank" rel="noopener noreferrer">DOI →</a>
              </div>
            )}
            {(p.data?.abstract ?? p.abstract) && (
              <details class="pub-abstract">
                <summary>{t.labels.abstract[lang]}</summary>
                <p>{p.data?.abstract ?? p.abstract}</p>
              </details>
            )}
            <div class="pub-tags">
              {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
              {(p.data?.lang ?? p.lang) && Array.isArray(p.data?.lang ?? p.lang) && (p.data?.lang ?? p.lang).map((l: string) => <span class="tag lang-tag">{l.toUpperCase()}</span>)}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Book chapters -->
  <section class="section" id="chapters">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.chapters[lang]}</h2>
      <ul class="pub-list rich with-covers">
        {showChapters.map((p: any) => {
          const year = p.data?.year ?? p.year;
          const publisher = p.data?.publisher ?? p.publisher ?? '';
          const coverKey = `${year}-${publisher}`;
          const cover = p.data?.cover ?? p.cover ?? chapterCovers[coverKey];
          return (
            <li class={cover ? 'pub-with-cover' : 'pub-list-item'}>
              {cover && <img class="pub-cover" src={cover} alt="" loading="lazy" />}
              <div class="pub-body">
                <div class="pub-meta muted">{year} &middot; {p.data?.venue ?? p.venue ?? publisher}</div>
                <div class="pub-title">{p.data?.title ?? p.title}</div>
                <div class="pub-authors muted">{authStr(p.data?.authors ?? p.authors)}</div>
                {(p.data?.abstract ?? p.abstract) && (
                  <details class="pub-abstract">
                    <summary>{t.labels.abstract[lang]}</summary>
                    <p>{p.data?.abstract ?? p.abstract}</p>
                  </details>
                )}
                <div class="pub-tags">
                  {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Policy & HR reports -->
  <section class="section full-bleed" id="reports">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.reports[lang]}</h2>
      <ul class="pub-list rich with-covers">
        {showReports.map((p: any) => {
          const cover = p.data?.cover ?? p.cover;
          return (
            <li class={cover ? 'pub-with-cover' : 'pub-list-item'}>
              {cover && <img class="pub-cover" src={cover} alt="" loading="lazy" />}
              <div class="pub-body">
                <div class="pub-meta muted">{p.data?.year ?? p.year} &middot; {authStr(p.data?.authors ?? p.authors)}</div>
                <div class="pub-title">
                  {(p.data?.url ?? p.url)
                    ? <a href={p.data?.url ?? p.url} target="_blank" rel="noopener noreferrer">{p.data?.title ?? p.title}</a>
                    : (p.data?.title ?? p.title)}
                </div>
                <div class="pub-tags">
                  {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Datasets -->
  <section class="section" id="datasets">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.datasets[lang]}</h2>
      <p class="section-body muted">
        Empirical datasets compiled during a decade of strategic litigation and human-rights practice.
        Structured and documented for reuse in sociolegal research.
      </p>
      <ul class="pub-list">
        <li>
          <span class="badge dataset">Dataset</span>
          <div class="pub-title">Citizen Interventions before the Colombian Constitutional Court (2016–2020)</div>
          <div class="pub-meta muted">Coded corpus of 30+ citizen interventions — court, ruling, topic, outcome, advocacy organization.</div>
          <div class="pub-meta muted"><em>Documentation in preparation. Available upon request.</em></div>
        </li>
        <li>
          <span class="badge dataset">Dataset</span>
          <div class="pub-title">Press Coverage of the Final Peace Agreement Implementation (2016–2019)</div>
          <div class="pub-meta muted">Scraped and hand-coded corpus of Colombian press coverage on peace-agreement implementation.</div>
          <div class="pub-meta muted"><em>Documentation in preparation. Available upon request.</em></div>
        </li>
      </ul>
      <p class="muted small" style="margin-top: var(--sp-4);">
        <a href={`mailto:${profile.email}`}>Request dataset access →</a>
      </p>
    </div>
  </section>

  <!-- Amicus note -->
  <section class="section full-bleed" id="interventions">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.interventions[lang]}</h2>
      <p class="section-body">
        The 30+ amicus curiae briefs and constitutional interventions I submitted between 2017 and 2023
        are documented separately on the <a href={`/${lang}/advocacy/`}>Advocacy &amp; Consulting</a> page,
        where each entry links to the published Constitutional Court ruling where available.
      </p>
      <p style="margin-top: var(--sp-4);">
        <a class="btn btn-outline" href={`/${lang}/advocacy/`}>View full interventions table →</a>
      </p>
    </div>
  </section>

  <!-- Research experience (moved below publications) -->
  <section class="section" id="experience">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">Research experience</h2>
      <ul class="exp-list">
        <li>
          <div class="exp-period muted">June–Aug. 2025</div>
          <div class="exp-role">Research Consultant</div>
          <div class="exp-host">Prof. Yanilda González · Harvard Kennedy School, Harvard University</div>
          <p class="exp-body">
            Specialized research on legal mechanisms for the investigation and sanctioning of
            aggressions and homicides committed by Colombia's <em>fuerza pública</em>. Mapped
            victims' and social-movement strategies for rights enforcement through legal and
            social channels. Consulting undertaken as part of Prof. González's forthcoming
            academic book on police accountability and state violence in Latin America.
          </p>
        </li>
        <li>
          <div class="exp-period muted">Aug–Oct 2017</div>
          <div class="exp-role">Research Fellow · Drug Policy and Transitional Justice</div>
          <div class="exp-host">CIDE — Center for Research and Teaching in Economics, Aguascalientes, Mexico</div>
          <p class="exp-body">
            Open Society Foundation Fellowship. Contributed to the Drug Policy Program's
            comparative study of transitional justice in Mexico and Colombia.
            Supervisor: Javier Treviño Rangel, Ph.D.
          </p>
        </li>
        <li>
          <div class="exp-period muted">2016–2017</div>
          <div class="exp-role">Research Assistant · Office of the Academic Vice President</div>
          <div class="exp-host">Universidad de los Andes, Bogotá</div>
          <p class="exp-body">
            Supported research coordination for a portfolio of peace-oriented studies responding
            to post-conflict educational needs in Colombia. Supervisor: Silvia Restrepo Restrepo, Ph.D.
          </p>
        </li>
        <li>
          <div class="exp-period muted">2013–2014</div>
          <div class="exp-role">Research Assistant · Socio-Legal Research Center (CIJUS)</div>
          <div class="exp-host">School of Law, Universidad de los Andes</div>
          <p class="exp-body">
            Contributed to <em>The Enforcement of Tutela Rulings in Colombia</em> (2012–2014), a
            joint project with Emory University and the World Bank — coded the complexity and
            clarity of court orders. Supervisor: Isabel Cristina Jaramillo, Ph.D.
          </p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .pub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .pub-list.rich li {
    border-left: 3px solid var(--rule);
    padding-left: var(--sp-4);
  }
  .pub-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.5;
    margin-block: var(--sp-1);
  }
  .pub-authors, .pub-meta { font-size: 0.85rem; }
  .pub-links { margin-top: var(--sp-1); }
  .pub-links a { font-size: 0.85rem; }
  .pub-abstract { margin-top: var(--sp-2); font-size: 0.9rem; }
  .pub-abstract summary { cursor: pointer; font-weight: 500; }
  .pub-tags { display: flex; flex-wrap: wrap; gap: var(--sp-1); margin-top: var(--sp-2); }
  .tag {
    font-size: 0.72rem;
    font-family: var(--font-sans);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    color: var(--accent-2);
    border: 1px solid color-mix(in srgb, var(--accent-2) 25%, transparent);
  }
  .lang-tag {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1em 0.55em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    margin-bottom: var(--sp-1);
  }
  .badge.wip {
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    color: var(--accent-2);
    border-color: color-mix(in srgb, var(--accent-2) 25%, transparent);
  }
  .badge.dataset {
    background: color-mix(in srgb, #4a6fa5 12%, transparent);
    color: #4a6fa5;
    border-color: color-mix(in srgb, #4a6fa5 25%, transparent);
  }
  .wip-placeholders {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-top: var(--sp-4);
  }
  .wip-slot {
    border-left: 3px dashed var(--rule);
    padding-left: var(--sp-4);
  }
  .wip-placeholder-title {
    margin-top: var(--sp-1);
    color: var(--muted);
    font-family: var(--font-serif);
  }
  .prose {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .exp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .exp-list li {
    border-left: 3px solid var(--rule);
    padding-left: var(--sp-4);
  }
  .exp-period {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .exp-role {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.4;
    margin-top: var(--sp-1);
  }
  .exp-host {
    font-size: 0.88rem;
    color: var(--muted);
    margin-top: 2px;
  }
  .exp-body {
    margin-top: var(--sp-2);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .pub-list.with-covers { gap: var(--sp-6); }
  .pub-list-item { border-left: 3px solid var(--rule); padding-left: var(--sp-4); }
  .pub-with-cover {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: var(--sp-4);
    align-items: start;
  }
  .pub-with-cover.pub-list.rich li,
  .pub-list.rich .pub-with-cover {
    /* keep border on body only */
  }
  .pub-cover {
    width: 112px;
    height: 150px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 6px 18px rgba(12, 29, 64, 0.18), 0 0 0 1px rgba(12, 29, 64, 0.08);
    display: block;
  }
  .pub-body { min-width: 0; }
  @media (max-width: 640px) {
    .pub-with-cover {
      grid-template-columns: 80px 1fr;
      gap: var(--sp-3);
    }
    .pub-cover { width: 80px; height: 107px; }
  }
</style>
