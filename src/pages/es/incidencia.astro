---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactInline from '~/components/ContactInline.astro';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';
import { interventions, courtLabel, interventionUrl, interventionsByYear } from '~/data/interventions';
import type { Lang } from '~/data/i18n';

const lang = 'es' as const;

const reports = [
  {
    year: 2020,
    authors: 'FIDH & CAJAR (Carretero Pardo, redactor principal)',
    title: 'Colombia en riesgo de impunidad: puntos ciegos de la justicia transicional frente a crímenes internacionales bajo jurisdicción de la CPI',
    url: null,
    tags: ['justicia transicional', 'CPI', 'Colombia'],
  },
  {
    year: 2020,
    authors: 'CSPP et al. (Carretero Pardo, coautor)',
    title: 'Desmantelamiento del paramilitarismo: propuesta de lineamientos de política pública',
    url: null,
    tags: ['paramilitarismo', 'política pública'],
  },
  {
    year: 2019,
    authors: 'CAJAR',
    title: 'Tejido de impunidad: voces de resistencia contra la violencia estatal y paramilitar en el Magdalena Medio (1998–2000)',
    url: null,
    tags: ['impunidad', 'derechos humanos', 'Colombia'],
  },
  {
    year: 2019,
    authors: 'CAJAR',
    title: 'La verdadera historia del pueblo Wiwa — Desde el corazón del mundo — en el contexto del conflicto armado interno (1990–2017)',
    url: null,
    tags: ['derechos indígenas', 'conflicto armado'],
  },
];

const sorted = interventionsByYear().filter(i => !i.tags?.includes('portfolio'));

const toc = [
  { id: 'overview',      label: 'Resumen' },
  { id: 'reports',       label: 'Reportes' },
  { id: 'interventions', label: 'Intervenciones' },
  { id: 'litigation',    label: 'Litigio' },
  { id: 'consulting',    label: 'Consultoría' },
  { id: 'contact',       label: 'Contacto' },
];
---
<BaseLayout
  title="Incidencia y Consultoría"
  description="Portafolio de litigio estratégico, amicus curiae e intervenciones constitucionales de José Jans Carretero Pardo — más de 30 intervenciones ante altas cortes colombianas, la CIDH y la CPI."
  lang={lang}
  current="advocacy"
  toc={toc}
>
  <!-- Foto conmemorativa, aspecto natural (sin recortar) -->
  <section class="section" style="padding-block-start: var(--sp-6);">
    <figure class="photo-inline wide reveal-fade">
      <img
        src="/photos/advocacy-memorial.jpg"
        alt="Vigilia conmemorativa de derechos humanos — Plaza de Bolívar, Bogotá — ¡Más vivos que nunca!"
        loading="eager"
        decoding="async"
      />
      <figcaption>¡Más vivos que nunca! · Vigilia conmemorativa · Plaza de Bolívar, Bogotá</figcaption>
    </figure>
  </section>

  <!-- Encabezado -->
  <section class="section" id="overview">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">{t.advocacy.eyebrow[lang]}</div>
      <h1 class="section-title">{t.advocacy.headline[lang]}</h1>
      <p class="lead">{t.advocacy.intro[lang]}</p>
    </div>
  </section>

  <!-- 1. Reportes de política y DDHH -->
  <section class="section full-bleed" id="reports">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.advocacy.sections.reports[lang]}</h2>
      <ul class="pub-list reveal-stagger">
        {reports.map((r) => (
          <li>
            <div class="pub-meta">{r.year} &middot; {r.authors}</div>
            <div class="pub-title">
              {r.url
                ? <a href={r.url} target="_blank" rel="noopener noreferrer">{r.title}</a>
                : r.title
              }
            </div>
            <div class="pub-tags">
              {r.tags.map(tag => <span class="badge">{tag}</span>)}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 2. Tabla de intervenciones -->
  <section class="section" id="interventions">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.advocacy.sections.interventions[lang]}</h2>
      <p class="section-body muted" style="max-width: var(--measure); margin-bottom: var(--sp-5);">
        Amicus curiae, intervenciones ciudadanas y acciones de inconstitucionalidad presentadas entre 2017 y 2023.
        Cuando está disponible, el número de sentencia enlaza directamente a la Relatoría de la Corte Constitucional.
      </p>
      <div style="overflow-x: auto;">
        <table class="intervention-table">
          <thead>
            <tr>
              <th>{t.labels.year[lang]}</th>
              <th>{t.labels.court[lang]}</th>
              <th>{t.labels.ruling[lang]}</th>
              <th>Tema</th>
              <th>Contexto</th>
            </tr>
          </thead>
          <tbody>
            {sorted.map((iv) => {
              const url = interventionUrl(iv);
              return (
                <tr>
                  <td>{iv.year}</td>
                  <td>{courtLabel[iv.court][lang]}</td>
                  <td>
                    {iv.ruling
                      ? url
                        ? <a href={url} target="_blank" rel="noopener noreferrer">{iv.ruling}</a>
                        : iv.ruling
                      : iv.caseNumber ?? '—'}
                  </td>
                  <td>{iv.topic[lang]}</td>
                  <td class="muted">{iv.ctx ? iv.ctx[lang] : ''}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="muted small" style="margin-top: var(--sp-4);">
        Esta lista cubre 26 intervenciones seleccionadas. El portafolio completo (30+) incluye presentaciones adicionales ante la CIDH y la CPI no listadas aquí.
        <a href={`mailto:${profile.email}`}>{t.labels.requestFullCaseLog[lang]} →</a>
      </p>
    </div>
  </section>

  <!-- 3. Litigio estratégico (JEP) -->
  <section class="section full-bleed" id="litigation">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.advocacy.sections.litigation[lang]}</h2>
      <div class="prose" style="font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.75;" set:html={bio.professional[lang]} />
    </div>
  </section>

  <!-- Foto tribunales inline, aspecto natural -->
  <section class="section">
    <figure class="photo-inline wide reveal-fade">
      <img
        src="/photos/advocacy-tribunales.jpg"
        alt="Equipo de litigio en los Tribunales de Bogotá — Consejo Superior de la Judicatura"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Tribunales de Bogotá · Equipo de litigio · Colombia</figcaption>
    </figure>
  </section>

  <!-- 4. Consultoría -->
  <section class="section" id="consulting">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.advocacy.sections.consulting[lang]}</h2>
      <p class="lead">{t.labels.availableFor[lang]}.</p>
      <p class="section-body">{t.advocacy.consultingBlurb[lang]}</p>
      <p style="margin-top: var(--sp-5);">
        <a class="btn btn-accent" href={`mailto:${profile.email}`}>Escríbeme →</a>
      </p>
    </div>
  </section>

  <!-- Contacto -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .pub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .pub-list li {
    border-left: 3px solid var(--accent);
    padding-left: var(--sp-4);
  }
  .pub-meta {
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--muted);
    margin-bottom: var(--sp-1);
  }
  .pub-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.5;
    margin-bottom: var(--sp-2);
  }
  .pub-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
  }
  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1em 0.55em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }
</style>
