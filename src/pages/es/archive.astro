---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('archive')).sort((a: any, b: any) => (b.data.year || 0) - (a.data.year || 0));

const groups = [
  { key: 'dataset', label: 'Bases de datos de investigación', items: items.filter((i: any) => i.data.kind === 'dataset') },
  { key: 'litigation', label: 'Portafolio de litigio estratégico', items: items.filter((i: any) => i.data.kind === 'litigation') },
  { key: 'writing', label: 'Escritos tempranos', items: items.filter((i: any) => i.data.kind === 'writing') },
  { key: 'report', label: 'Reportes anteriores', items: items.filter((i: any) => i.data.kind === 'report') },
];
---
<BaseLayout title="Archivo de investigación" lang="es" current="archive">
  <h1>Archivo de investigación</h1>

  <p>
    Fundamentos empíricos de mi agenda de investigación actual, construidos en una década de
    litigio de interés público y práctica en derechos humanos en Colombia. Esta sección preserva
    bases de datos, portafolios de casos y escritos anteriores que surgieron fuera de la
    academia pero alimentan directamente mi trabajo doctoral sobre justicia transicional,
    movilización de derechos y rendición de cuentas del Estado.
  </p>

  {groups.map((g) => g.items.length > 0 && (
    <section class="archive-group">
      <h2>{g.label}</h2>
      <ul class="archive-list">
        {g.items.map((item: any) => (
          <li>
            <h3>{item.data.title}</h3>
            {item.data.year && <div class="pub-meta">{item.data.year}</div>}
            {item.data.summary && <p>{item.data.summary}</p>}
            <p class="small"><a href={`/es/archive/${item.id.replace(/\.(md|mdx)$/, '')}/`}>Leer más →</a></p>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
