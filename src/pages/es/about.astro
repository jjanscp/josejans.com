---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Avatar from '~/components/Avatar.astro';
import ImagePlaceholder from '~/components/ImagePlaceholder.astro';
import ContactInline from '~/components/ContactInline.astro';
import { profile } from '~/data/profile';
import { bio } from '~/data/bio';

const lang = 'es' as const;
---
<BaseLayout
  title="Sobre mí"
  description={`Sobre ${profile.name} — estudiante doctoral en Ciencia Política en UIC, becario Fulbright–MinCiencias, ex abogado líder en la JEP y abogado senior en CAJAR.`}
  lang={lang}
  current="about"
>
  <!-- Encabezado -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Sobre mí</div>
      <h1 class="section-title">{profile.name}</h1>
      <p class="lead">{profile.title[lang]} &middot; {profile.affiliation[lang]}</p>
    </div>
  </section>

  <!-- Foto de portada -->
  <section class="section full-bleed" style="padding-block: 0;">
    <ImagePlaceholder
      kind="landscape"
      emoji="📷"
      desc="Foto de portada — en campo, en audiencia o en el aula"
      spec="2400×900 JPG · fondo oscuro o neutro preferido"
    />
  </section>

  <!-- Bloque 1: Agenda de investigación -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Estudiante doctoral · Becario Fulbright</div>
      <h2 class="section-title">La agenda de investigación</h2>
      <div class="section-body prose" set:html={bio.research[lang]} />
      <h3 style="margin-top: var(--sp-6);">Intereses de investigación</h3>
      <ul class="interest-list">
        {bio.interests[lang].map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- Bloque 2: Trayectoria de práctica profesional -->
  <section class="section full-bleed">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">2015–2024 · Colombia</div>
      <h2 class="section-title">Una década de práctica de primera línea</h2>
      <div class="section-body prose" set:html={bio.professional[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="section-cta" href={`/${lang}/incidencia/`}>
          Ver portafolio completo de incidencia →
        </a>
      </p>
    </div>
  </section>

  <!-- Bloque 3: Docencia -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Educación jurídica · Colombia</div>
      <h2 class="section-title">Docencia y trabajo clínico</h2>
      <div class="section-body prose" set:html={bio.teaching[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="section-cta" href={`/${lang}/teaching/`}>
          Portafolio de docencia →
        </a>
      </p>
      <div style="margin-top: var(--sp-6);">
        <ImagePlaceholder
          kind="landscape"
          emoji="🏛️"
          desc="Foto de aula o clínica — seminario UIS o Uniandes"
          spec="1200×600 JPG"
        />
      </div>
    </div>
  </section>

  <!-- Bloque 4: Historia personal -->
  <section class="section full-bleed">
    <div class="section-inner" style="max-width: var(--measure);">
      <div class="section-eyebrow">Más allá del trabajo</div>
      <h2 class="section-title">Un poco más sobre mí</h2>
      <div class="section-body prose" set:html={bio.personal[lang]} />
    </div>
  </section>

  <!-- Bloque 5: Formación -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <h2 class="section-title">Formación académica</h2>
      <ul class="cv-list">
        {bio.education[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Formación adicional</h3>
      <ul class="cv-list">
        {bio.training[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Afiliaciones</h3>
      <ul class="cv-list">
        {bio.affiliations[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 style="margin-top: var(--sp-6);">Idiomas</h3>
      <p>{bio.languages[lang]}</p>

      <p style="margin-top: var(--sp-6);">
        <a class="btn btn-outline" href="/cv.pdf" target="_blank" rel="noopener">Descargar hoja de vida (PDF)</a>
      </p>
    </div>
  </section>

  <!-- Contacto -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .interest-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .interest-list li {
    padding-left: var(--sp-4);
    position: relative;
  }
  .interest-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-sans);
  }
  .cv-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .cv-list li {
    border-left: 3px solid var(--rule);
    padding-left: var(--sp-4);
    line-height: 1.65;
  }
  .prose {
    line-height: 1.75;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
</style>
