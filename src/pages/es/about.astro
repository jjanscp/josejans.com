---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactInline from '~/components/ContactInline.astro';
import { profile } from '~/data/profile';
import { bio } from '~/data/bio';

const lang = 'es' as const;

const navItems = [
  { id: 'about',        label: 'Sobre mí' },
  { id: 'research',     label: 'Investigación' },
  { id: 'professional', label: 'Trayectoria' },
  { id: 'teaching',     label: 'Docencia' },
  { id: 'personal',     label: 'Más' },
  { id: 'education',    label: 'Formación' },
  { id: 'contact',      label: 'Contacto' },
];
---
<BaseLayout
  title="Sobre mí"
  description={`Sobre ${profile.name} — estudiante doctoral en Ciencia Política en UIC, becario Fulbright–MinCiencias, ex abogado líder en la JEP y abogado senior en CAJAR.`}
  lang={lang}
  current="about"
  toc={navItems}
  tocLabel="Contenido"
>

  <!-- Sin banner recortado. Las fotos viven inline a aspecto natural dentro de cada sección. -->

  <!-- Sobre mí: layout dividido — foto izquierda, bio derecha -->
  <section class="section" id="about">
    <div class="section-inner">
      <div class="about-split">
        <!-- Columna de foto -->
        <div class="photo-col reveal">
          <img
            class="photo-profile"
            src="/photos/headshot.jpg"
            alt="José Jans Carretero Pardo"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Columna de texto -->
        <div class="reveal">
          <div class="section-eyebrow">Estudiante doctoral · Becario Fulbright</div>
          <h1 class="section-title">{profile.name}</h1>
          <p class="lead">{profile.title[lang]} &middot; {profile.affiliation[lang]}</p>
          <div style="margin-top: var(--sp-5);" class="prose" set:html={bio.short[lang]} />
          <div style="margin-top: var(--sp-5); display:flex; gap: var(--sp-3); flex-wrap: wrap;">
            <a class="btn btn-primary" href={`/${lang}/research/`}>Investigación y Publicaciones</a>
            <a class="btn btn-outline" href="/cv.pdf" target="_blank" rel="noopener">Descargar hoja de vida</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Agenda de investigación -->
  <section class="section dark full-bleed" id="research">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="section-eyebrow reveal">Agenda de investigación</div>
      <h2 class="section-title reveal">La agenda de investigación</h2>
      <div class="reveal" set:html={bio.research[lang]} />
    </div>
  </section>

  <!-- Trayectoria profesional + retrato JEP -->
  <section class="section" id="professional">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="photo-split reveal">
        <img
          src="/photos/portrait-jep.jpg"
          alt="José Jans Carretero Pardo en la Jurisdicción Especial para la Paz (JEP), Bogotá"
          loading="lazy"
          decoding="async"
        />
        <div>
          <div class="section-eyebrow">2015–2024 · Colombia</div>
          <h2 class="section-title">Una década de práctica de primera línea</h2>
          <div class="section-body prose" set:html={bio.professional[lang]} />
          <p style="margin-top: var(--sp-4);">
            <a class="btn btn-outline" href={`/${lang}/advocacy/`}>Portafolio completo de incidencia →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Docencia (la foto de la clínica vive en la página de docencia) -->
  <section class="section full-bleed" style="background: var(--bg-subtle);" id="teaching">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Educación jurídica · Colombia</div>
      <h2 class="section-title">Docencia y trabajo clínico</h2>
      <div class="section-body prose" set:html={bio.teaching[lang]} />
      <p style="margin-top: var(--sp-4);">
        <a class="btn btn-outline" href={`/${lang}/teaching/`}>Portafolio de docencia →</a>
      </p>
    </div>
  </section>

  <!-- Vida personal -->
  <section class="section" id="personal">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <div class="section-eyebrow">Más allá del trabajo</div>
      <h2 class="section-title">Un poco más sobre mí</h2>
      <div class="section-body prose" set:html={bio.personal[lang]} />
    </div>
    <!-- Foto Ironman inline, aspecto natural -->
    <figure class="photo-inline reveal-fade">
      <img
        src="/photos/personal-ironman.jpg"
        alt="Ironman 70.3 Cartagena Colombia — meta"
        loading="lazy"
        decoding="async"
      />
      <figcaption>Ironman 70.3 Cartagena · Colombia</figcaption>
    </figure>
  </section>

  <!-- Formación académica -->
  <section class="section dark full-bleed" id="education">
    <div class="section-inner" style="max-width: var(--measure);">
      <h2 class="section-title reveal">Formación académica</h2>
      <ul class="edu-list reveal-stagger">
        {bio.education[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 class="reveal" style="font-size:1rem; margin-top: var(--sp-6); margin-bottom: var(--sp-3); color: var(--cream); font-family: var(--font-sans); text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem;">Formación adicional</h3>
      <ul class="edu-list reveal-stagger">
        {bio.training[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <h3 class="reveal" style="font-size:1rem; margin-top: var(--sp-6); margin-bottom: var(--sp-3); color: var(--cream); font-family: var(--font-sans); text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem;">Afiliaciones</h3>
      <ul class="edu-list reveal-stagger">
        {bio.affiliations[lang].map((item) => (
          <li set:html={item} />
        ))}
      </ul>

      <p class="reveal" style="margin-top: var(--sp-3); color: var(--text-on-dark-muted);">
        Idiomas: {bio.languages[lang]}
      </p>

      <p style="margin-top: var(--sp-6);" class="reveal">
        <a class="btn btn-ghost-light" href="/cv.pdf" target="_blank" rel="noopener">Descargar hoja de vida completa (PDF)</a>
      </p>
    </div>
  </section>

  <!-- Contacto -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .dark-list li { color: var(--text-on-dark-muted); }
  .dark-list li::before { color: var(--gold); }
  .about-split .photo-col { align-self: start; }
</style>
