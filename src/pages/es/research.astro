---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import { getCollection } from 'astro:content';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';
import { profile } from '~/data/profile';

const lang = 'es' as const;

const all = (await getCollection('publications', (p: any) => p.data.lang === 'es' || !p.data.lang))
  .sort((a: any, b: any) => b.data.year - a.data.year);

const articles  = all.filter((p: any) => p.data.type === 'article');
const chapters  = all.filter((p: any) => p.data.type === 'chapter');
const reports   = all.filter((p: any) => p.data.type === 'report');
const wip       = all.filter((p: any) => p.data.type === 'wip');

const staticArticles = [
  {
    authors: 'Carretero Pardo, J. J., & Ochoa Sterling, T.',
    year: 2021,
    title: 'Campos en disputa en la protección de líderes sociales en Colombia',
    venue: 'IdeAs — Idées d\'Amériques',
    volume: '17',
    url: 'https://journals.openedition.org/ideas/10381?lang=en',
    doi: '10.4000/ideas.10381',
    abstract: 'Analiza la protección de líderes sociales desde la perspectiva de las redes transnacionales de derechos humanos y el marco de justicia transicional colombiano.',
    tags: ['líderes sociales', 'justicia transicional', 'derechos humanos', 'Colombia'],
    lang: ['es', 'fr', 'en'],
  },
];

const staticChapters = [
  {
    authors: 'Carretero Pardo, J. J., & Rodríguez, C.',
    year: 2018,
    title: 'De La Habana al Congreso colombiano: ¿dónde quedaron los derechos de las víctimas en la implementación del Acuerdo Final?',
    venue: 'Discusiones sobre la implementación del acuerdo final entre el Gobierno colombiano y las FARC-EP',
    publisher: 'Universidad Libre',
    abstract: 'Examina las disposiciones sobre derechos de las víctimas en la implementación legislativa del Acuerdo Final de Paz de 2016.',
    tags: ['derechos de víctimas', 'acuerdo de paz', 'Colombia', 'justicia transicional'],
  },
];

const staticReports = [
  {
    authors: 'FIDH & CAJAR (Carretero Pardo, J. J., redactor principal)',
    year: 2020,
    title: 'Colombia en riesgo de impunidad: puntos ciegos de la justicia transicional frente a crímenes internacionales bajo jurisdicción de la CPI',
    tags: ['justicia transicional', 'CPI', 'impunidad', 'Colombia'],
    cover: '/covers/cover-fidh-2020.jpg',
  },
  {
    authors: 'CSPP et al. (Carretero Pardo, J. J., coautor)',
    year: 2020,
    title: 'Desmantelamiento del paramilitarismo: propuesta de lineamientos de política pública',
    tags: ['paramilitarismo', 'política pública', 'Colombia'],
    cover: '/covers/cover-desmantel-2020.jpg',
  },
  {
    authors: 'CAJAR (Carretero Pardo, J. J., colaborador)',
    year: 2019,
    title: 'Tejido de impunidad, voces de resistencia contra la violencia estatal y paramilitar en el Magdalena Medio (1998–2000)',
    tags: ['impunidad', 'derechos humanos', 'Colombia'],
    cover: '/covers/cover-telaranas-2019.jpg',
  },
  {
    authors: 'CAJAR (Carretero Pardo, J. J., colaborador)',
    year: 2019,
    title: 'La verdadera historia del pueblo Wiwa, desde el corazón del mundo, en el contexto del conflicto armado interno (1990–2017)',
    tags: ['derechos indígenas', 'conflicto armado', 'Colombia'],
    cover: '/covers/cover-wiwa-2019.jpg',
  },
];

// Portadas de capítulos (por año + editorial si no hay entrada en CMS)
const chapterCovers: Record<string, string> = {
  '2018-Universidad Libre': '/covers/cover-libre-2018.jpg',
};

const showArticles = articles.length > 0 ? articles : staticArticles;
const showChapters = chapters.length > 0 ? chapters : staticChapters;
const showReports  = reports.length  > 0 ? reports  : staticReports;

// Helper: handle authors as string OR array (CMS entries use array; static entries use string)
const authStr = (a: string | string[] | undefined): string =>
  Array.isArray(a) ? a.join(', ') : (a ?? '');

const toc = [
  { id: 'agenda',        label: 'Agenda' },
  { id: 'wip',           label: 'En curso' },
  { id: 'articles',      label: 'Artículos' },
  { id: 'chapters',      label: 'Capítulos' },
  { id: 'reports',       label: 'Reportes' },
  { id: 'datasets',      label: 'Bases de datos' },
  { id: 'interventions', label: 'Intervenciones' },
  { id: 'experience',    label: 'Experiencia' },
];
---
<BaseLayout
  title="Investigación y Publicaciones"
  description="Agenda de investigación, artículos académicos, capítulos de libro, reportes de política y bases de datos de José Jans Carretero Pardo sobre justicia transicional, cortes y derechos."
  lang={lang}
  current="research"
  toc={toc}
>
  <!-- Foto hero -->
  <SectionHero
    src="/photos/advocacy-memorial.jpg"
    alt="Vigilia conmemorativa de derechos humanos, Plaza de Bolívar, Bogotá"
    caption="¡Más vivos que nunca! · Vigilia conmemorativa · Plaza de Bolívar, Bogotá"
    position="center 40%"
  />

  <!-- Cabecera + agenda de investigación completa (pilares) -->
  <section class="section dark full-bleed" id="agenda">
    <div class="section-inner" style="max-width: var(--measure-wide);">
      <div class="section-eyebrow reveal">Agenda de investigación</div>
      <h1 class="section-title reveal">La agenda de investigación</h1>
      <div class="reveal" set:html={bio.research[lang]} />
    </div>
  </section>

  <!-- Trabajos en curso (bio.wip — datos bilingües) -->
  <section class="section" id="wip">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.wip[lang]}</h2>
      {wip.length > 0 ? (
        <ul class="pub-list">
          {wip.map((p: any) => (
            <li class="wip-slot">
              <span class="badge wip">{p.data.status || t.labels.inPreparation[lang]}</span>
              <div class="pub-title">{p.data.title}</div>
              <div class="pub-meta muted">{p.data.authors?.join(', ')} · {p.data.year}</div>
              {p.data.abstract && (
                <details class="pub-abstract"><summary>{t.labels.abstract[lang]}</summary><p>{p.data.abstract}</p></details>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <ul class="pub-list wip-list">
          {bio.wip.map((p) => (
            <li class="wip-slot">
              <span class="badge wip">{p.status[lang]}</span>
              <div class="pub-title">{p.title[lang]}</div>
              <div class="pub-meta muted">{p.authors[lang]}</div>
              <details class="pub-abstract">
                <summary>{t.labels.abstract[lang]}</summary>
                <p>{p.abstract[lang]}</p>
              </details>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section full-bleed" id="articles">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.peerReviewed[lang]}</h2>
      <ul class="pub-list rich">
        {showArticles.map((p: any) => (
          <li>
            <div class="pub-meta muted">{p.data?.year ?? p.year} &middot; {p.data?.venue ?? p.venue}{(p.data?.volume ?? p.volume) ? `, ${p.data?.volume ?? p.volume}` : ''}</div>
            <div class="pub-title">
              {(p.data?.url ?? p.url)
                ? <a href={p.data?.url ?? p.url} target="_blank" rel="noopener noreferrer">{p.data?.title ?? p.title}</a>
                : (p.data?.title ?? p.title)}
            </div>
            <div class="pub-authors muted">{authStr(p.data?.authors ?? p.authors)}</div>
            {(p.data?.doi ?? p.doi) && (
              <div class="pub-links"><a href={`https://doi.org/${p.data?.doi ?? p.doi}`} target="_blank" rel="noopener noreferrer">DOI →</a></div>
            )}
            {(p.data?.abstract ?? p.abstract) && (
              <details class="pub-abstract"><summary>{t.labels.abstract[lang]}</summary><p>{p.data?.abstract ?? p.abstract}</p></details>
            )}
            <div class="pub-tags">
              {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section" id="chapters">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.chapters[lang]}</h2>
      <ul class="pub-list rich with-covers">
        {showChapters.map((p: any) => {
          const year = p.data?.year ?? p.year;
          const publisher = p.data?.publisher ?? p.publisher ?? '';
          const coverKey = `${year}-${publisher}`;
          const cover = p.data?.cover ?? p.cover ?? chapterCovers[coverKey];
          return (
            <li class={cover ? 'pub-with-cover' : 'pub-list-item'}>
              {cover && <img class="pub-cover" src={cover} alt="" loading="lazy" />}
              <div class="pub-body">
                <div class="pub-meta muted">{year} &middot; {p.data?.venue ?? p.venue ?? publisher}</div>
                <div class="pub-title">{p.data?.title ?? p.title}</div>
                <div class="pub-authors muted">{authStr(p.data?.authors ?? p.authors)}</div>
                {(p.data?.abstract ?? p.abstract) && (
                  <details class="pub-abstract"><summary>{t.labels.abstract[lang]}</summary><p>{p.data?.abstract ?? p.abstract}</p></details>
                )}
                <div class="pub-tags">
                  {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="section full-bleed" id="reports">
    <div class="section-inner reveal">
      <h2 class="section-title">{t.sections.reports[lang]}</h2>
      <ul class="pub-list rich with-covers">
        {showReports.map((p: any) => {
          const cover = p.data?.cover ?? p.cover;
          return (
            <li class={cover ? 'pub-with-cover' : 'pub-list-item'}>
              {cover && <img class="pub-cover" src={cover} alt="" loading="lazy" />}
              <div class="pub-body">
                <div class="pub-meta muted">{p.data?.year ?? p.year} &middot; {authStr(p.data?.authors ?? p.authors)}</div>
                <div class="pub-title">
                  {(p.data?.url ?? p.url)
                    ? <a href={p.data?.url ?? p.url} target="_blank" rel="noopener noreferrer">{p.data?.title ?? p.title}</a>
                    : (p.data?.title ?? p.title)}
                </div>
                <div class="pub-tags">
                  {(p.data?.tags ?? p.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="section" id="datasets">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.datasets[lang]}</h2>
      <p class="section-body muted">Bases de datos empíricas compiladas durante una década de litigio estratégico y práctica de derechos humanos. Estructuradas y documentadas para su reutilización en investigación sociojurídica.</p>
      <ul class="pub-list">
        <li>
          <span class="badge dataset">Base de datos</span>
          <div class="pub-title">Intervenciones ciudadanas ante la Corte Constitucional colombiana (2016–2020)</div>
          <div class="pub-meta muted">Corpus codificado de 30+ intervenciones: corte, sentencia, tema, resultado, organización.</div>
          <div class="pub-meta muted"><em>Documentación en preparación. Disponible bajo solicitud.</em></div>
        </li>
        <li>
          <span class="badge dataset">Base de datos</span>
          <div class="pub-title">Cubrimiento de prensa sobre la implementación del Acuerdo Final (2016–2019)</div>
          <div class="pub-meta muted">Corpus raspado y codificado a mano de prensa colombiana sobre la implementación del acuerdo de paz.</div>
          <div class="pub-meta muted"><em>Documentación en preparación. Disponible bajo solicitud.</em></div>
        </li>
      </ul>
      <p class="muted small" style="margin-top: var(--sp-4);">
        <a href={`mailto:${profile.email}`}>Solicitar acceso a bases de datos →</a>
      </p>
    </div>
  </section>

  <section class="section full-bleed" id="interventions">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">{t.sections.interventions[lang]}</h2>
      <p class="section-body">
        Los más de 30 amicus curiae e intervenciones constitucionales presentados entre 2017 y 2023
        están documentados en la página de <a href={`/${lang}/incidencia/`}>Incidencia y Consultoría</a>,
        donde cada entrada enlaza con la sentencia publicada por la Corte Constitucional cuando está disponible.
      </p>
      <p style="margin-top: var(--sp-4);">
        <a class="btn btn-outline" href={`/${lang}/incidencia/`}>Ver tabla completa de intervenciones →</a>
      </p>
    </div>
  </section>

  <!-- Experiencia de investigación (movida al final, después de publicaciones) -->
  <section class="section" id="experience">
    <div class="section-inner reveal" style="max-width: var(--measure);">
      <h2 class="section-title">Experiencia de investigación</h2>
      <ul class="exp-list">
        <li>
          <div class="exp-period muted">Jun.–Ago. 2025</div>
          <div class="exp-role">Consultor de investigación</div>
          <div class="exp-host">Prof. Yanilda González · Harvard Kennedy School, Harvard University</div>
          <p class="exp-body">
            Investigación especializada sobre los mecanismos jurídicos para la investigación y
            sanción de agresiones y homicidios cometidos por la <em>fuerza pública</em> en
            Colombia. Mapeé las estrategias de víctimas y movimientos sociales para la exigibilidad
            de derechos a través de canales legales y sociales. Consultoría realizada como parte del
            próximo libro académico de la Prof. González sobre rendición de cuentas policial y
            violencia estatal en América Latina.
          </p>
        </li>
        <li>
          <div class="exp-period muted">Ago–Oct 2017</div>
          <div class="exp-role">Investigador · Política de Drogas y Justicia Transicional</div>
          <div class="exp-host">CIDE — Centro de Investigación y Docencia Económicas, Aguascalientes, México</div>
          <p class="exp-body">
            Beca Open Society Foundation. Contribuí al Programa de Política de Drogas en un estudio
            comparado de la justicia transicional en México y Colombia.
            Supervisor: Javier Treviño Rangel, Ph.D.
          </p>
        </li>
        <li>
          <div class="exp-period muted">2016–2017</div>
          <div class="exp-role">Asistente de investigación · Vicerrectoría Académica</div>
          <div class="exp-host">Universidad de los Andes, Bogotá</div>
          <p class="exp-body">
            Apoyé la coordinación de un portafolio de investigación orientado a la paz, en
            respuesta a las necesidades educativas del posconflicto en Colombia.
            Supervisora: Silvia Restrepo Restrepo, Ph.D.
          </p>
        </li>
        <li>
          <div class="exp-period muted">2013–2014</div>
          <div class="exp-role">Asistente de investigación · CIJUS</div>
          <div class="exp-host">Facultad de Derecho, Universidad de los Andes</div>
          <p class="exp-body">
            Contribuí a <em>La efectividad de las sentencias de tutela en Colombia</em> (2012–2014),
            un proyecto conjunto con Emory University y el Banco Mundial. Codifiqué la complejidad
            y claridad de las órdenes judiciales. Supervisora: Isabel Cristina Jaramillo, Ph.D.
          </p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .pub-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--sp-5); }
  .pub-list.rich li { border-left: 3px solid var(--rule); padding-left: var(--sp-4); }
  .pub-title { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.5; margin-block: var(--sp-1); }
  .pub-authors, .pub-meta { font-size: 0.85rem; }
  .pub-links { margin-top: var(--sp-1); }
  .pub-links a { font-size: 0.85rem; }
  .pub-abstract { margin-top: var(--sp-2); font-size: 0.9rem; }
  .pub-abstract summary { cursor: pointer; font-weight: 500; }
  .pub-tags { display: flex; flex-wrap: wrap; gap: var(--sp-1); margin-top: var(--sp-2); }
  .tag { font-size: 0.72rem; font-family: var(--font-sans); padding: 0.1em 0.5em; border-radius: 3px;
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    color: var(--accent-2); border: 1px solid color-mix(in srgb, var(--accent-2) 25%, transparent); }
  .badge { display: inline-block; font-size: 0.72rem; font-family: var(--font-sans); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em; padding: 0.1em 0.55em; border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); margin-bottom: var(--sp-1); }
  .badge.wip { background: color-mix(in srgb, var(--accent-2) 12%, transparent); color: var(--accent-2);
    border-color: color-mix(in srgb, var(--accent-2) 25%, transparent); }
  .badge.dataset { background: color-mix(in srgb, #4a6fa5 12%, transparent); color: #4a6fa5;
    border-color: color-mix(in srgb, #4a6fa5 25%, transparent); }
  .wip-placeholders { display: flex; flex-direction: column; gap: var(--sp-4); margin-top: var(--sp-4); }
  .wip-slot { border-left: 3px dashed var(--rule); padding-left: var(--sp-4); }
  .wip-placeholder-title { margin-top: var(--sp-1); color: var(--muted); font-family: var(--font-serif); }
  .prose { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.75; }
  .exp-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: var(--sp-5);
  }
  .exp-list li { border-left: 3px solid var(--rule); padding-left: var(--sp-4); }
  .exp-period { font-family: var(--font-sans); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .exp-role { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.4; margin-top: var(--sp-1); }
  .exp-host { font-size: 0.88rem; color: var(--muted); margin-top: 2px; }
  .exp-body { margin-top: var(--sp-2); font-size: 0.95rem; line-height: 1.65; }
  .pub-list.with-covers { gap: var(--sp-6); }
  .pub-list-item { border-left: 3px solid var(--rule); padding-left: var(--sp-4); }
  .pub-with-cover {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: var(--sp-4);
    align-items: start;
  }
  .pub-cover {
    width: 112px;
    height: 150px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 6px 18px rgba(12, 29, 64, 0.18), 0 0 0 1px rgba(12, 29, 64, 0.08);
    display: block;
  }
  .pub-body { min-width: 0; }
  @media (max-width: 640px) {
    .pub-with-cover { grid-template-columns: 80px 1fr; gap: var(--sp-3); }
    .pub-cover { width: 80px; height: 107px; }
  }
</style>
