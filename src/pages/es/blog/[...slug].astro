---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = (await getCollection('posts', (p: any) => p.data.lang === 'es' && !p.data.draft));
  return entries.map((entry: any) => ({ params: { slug: entry.id.replace(/\.(md|mdx)$/, '') }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} lang="es" current="blog">
  <article class="prose">
    <h1>{entry.data.title}</h1>
    <p class="pub-meta">
      <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </p>
    <Content />
    <p class="small"><a href="/es/blog/">← Todas las entradas</a></p>
  </article>
</BaseLayout>
