---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomeHero from '~/components/HomeHero.astro';
import Promise from '~/components/Promise.astro';
import SectionTease from '~/components/SectionTease.astro';
import LatestPosts from '~/components/LatestPosts.astro';
import SocialRow from '~/components/SocialRow.astro';
import NewsletterEmbed from '~/components/NewsletterEmbed.astro';
import ContactInline from '~/components/ContactInline.astro';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';

const lang = 'es' as const;

const researchItems = [
  {
    year: 2021,
    meta: 'IdeAs — Idées d\'Amériques',
    title: 'Campos en disputa en la protección de líderes sociales en Colombia',
    href: 'https://journals.openedition.org/ideas/10688',
  },
  {
    year: 2020,
    meta: 'Reporte FIDH & CAJAR',
    title: 'Colombia en riesgo de impunidad: puntos ciegos de la justicia transicional frente a crímenes internacionales',
  },
  {
    year: 2018,
    meta: 'Capítulo de libro — Universidad Libre',
    title: 'De La Habana al Congreso colombiano: ¿dónde quedaron los derechos de las víctimas?',
  },
];

const advocacyItems = [
  {
    year: '2019–2020',
    meta: 'Corte Constitucional',
    title: 'Derechos de las víctimas en la Ley de Procedimiento de la JEP — C-590/2019, C-050/2020',
  },
  {
    year: '2022–2023',
    meta: 'Corte Constitucional',
    title: 'Libertad de expresión y derechos indígenas — T-087/2023, SU-545/2023, SU-546/2023',
  },
  {
    year: 2018,
    meta: 'Consejo de Estado',
    title: 'Política de drogas como asunto de salud pública — 201800444',
  },
];

const teachingItems = [
  {
    meta: 'Clínica Jurídica UIS',
    title: 'Coordinador fundador — Clínica de Litigio Estratégico Carlos Gaviria Díaz',
  },
  {
    meta: 'Maestría UIS',
    title: 'Metodologías de Investigación en Derechos Humanos',
  },
  {
    meta: 'Universidad de los Andes',
    title: 'Asistente docente e investigador · CIJUS',
  },
];
---
<BaseLayout
  title={profile.name}
  description={`${profile.name} — Estudiante doctoral en Ciencia Política en UIC, becario Fulbright–MinCiencias. Investigación sobre justicia transicional, cortes y movilización de derechos.`}
  lang={lang}
  current="home"
>
  <!-- 1. Hero -->
  <HomeHero lang={lang} />

  <!-- 2. Promise -->
  <Promise lang={lang} />

  <!-- 3. Short bio -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <p class="lead" set:html={bio.short[lang]} />
    </div>
  </section>

  <!-- 4. Research & Publications tease -->
  <SectionTease
    lang={lang}
    eyebrow={t.home.researchEyebrow[lang]}
    title="Artículos arbitrados, reportes de política y bases de datos de investigación."
    body={t.home.researchBody[lang]}
    href={`/${lang}/research/`}
    ctaLabel={t.labels.viewFull[lang]}
    items={researchItems}
    variant="subtle"
  />

  <!-- 5. Advocacy & Consulting tease -->
  <SectionTease
    lang={lang}
    eyebrow={t.home.advocacyEyebrow[lang]}
    title="Más de treinta amicus curiae e intervenciones constitucionales."
    body={t.home.advocacyBody[lang]}
    href={`/${lang}/incidencia/`}
    ctaLabel={t.labels.viewFull[lang]}
    items={advocacyItems}
    variant="light"
  />

  <!-- 6. Teaching tease -->
  <SectionTease
    lang={lang}
    eyebrow={t.home.teachingEyebrow[lang]}
    title="Docencia clínica, constitucional y metodológica."
    body={t.home.teachingBody[lang]}
    href={`/${lang}/teaching/`}
    ctaLabel={t.labels.viewFull[lang]}
    items={teachingItems}
    variant="subtle"
  />

  <!-- 7. Latest from blog -->
  <LatestPosts lang={lang} limit={3} />

  <!-- 8. Social row -->
  <section class="section">
    <div class="section-inner">
      <div class="section-eyebrow">Encuéntrame en línea</div>
      <SocialRow lang={lang} />
    </div>
  </section>

  <!-- 9. Newsletter -->
  <section class="section full-bleed" id="newsletter">
    <div class="section-inner">
      <NewsletterEmbed lang={lang} />
    </div>
  </section>

  <!-- 10. Contact -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>
