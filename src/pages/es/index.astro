---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomeHero from '~/components/HomeHero.astro';
import Promise from '~/components/Promise.astro';
import SectionTease from '~/components/SectionTease.astro';
import SocialRow from '~/components/SocialRow.astro';
import NewsletterEmbed from '~/components/NewsletterEmbed.astro';
import ContactInline from '~/components/ContactInline.astro';
import { getCollection } from 'astro:content';
import { fetchSubstackFeed } from '~/lib/substackFeed';
import { profile } from '~/data/profile';
import { t } from '~/data/i18n';
import { bio } from '~/data/bio';

const lang = 'es' as const;

// Fetch latest posts for home preview
const localPosts = (await getCollection('posts', (p: any) => p.data.lang === 'es' && !p.data.draft))
  .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const feedUrl = profile.social.substack ? `${profile.social.substack}/feed` : null;
const substackRaw = feedUrl ? (await fetchSubstackFeed(feedUrl, 3)) : [];

// Merge local + Substack, take top 3 by date
const latestPosts = [
  ...localPosts.map((p: any) => ({
    date: p.data.date as Date,
    title: p.data.title as string,
    summary: (p.data.summary ?? '') as string,
    href: `/${lang}/blog/${p.id.replace(/\.(md|mdx)$/, '')}/`,
    external: false,
  })),
  ...substackRaw.map((p) => ({
    date: p.published,
    title: p.title,
    summary: p.summary ?? '',
    href: p.url,
    external: true,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 3);

const researchItems = [
  {
    year: 2021,
    meta: "IdeAs \u2014 Id\u00e9es d'Am\u00e9riques",
    title: 'Campos en disputa en la protecci\u00f3n de l\u00edderes sociales en Colombia',
    href: 'https://journals.openedition.org/ideas/10381?lang=en',
  },
  {
    year: 2020,
    meta: 'Reporte FIDH & CAJAR',
    title: 'Colombia en riesgo de impunidad: puntos ciegos de la justicia transicional frente a cr\u00edmenes internacionales',
  },
  {
    year: 2018,
    meta: 'Cap\u00edtulo de libro \u2014 Universidad Libre',
    title: 'De La Habana al Congreso colombiano: \u00bfd\u00f3nde quedaron los derechos de las v\u00edctimas?',
  },
];

const advocacyItems = [
  {
    year: '2019\u20132020',
    meta: 'Corte Constitucional',
    title: 'Derechos de las v\u00edctimas en la Ley de Procedimiento de la JEP \u2014 C-590/2019, C-050/2020',
  },
  {
    year: '2022\u20132023',
    meta: 'Corte Constitucional',
    title: 'Libertad de expresi\u00f3n y derechos ind\u00edgenas \u2014 T-087/2023, SU-545/2023, SU-546/2023',
  },
  {
    year: 2018,
    meta: 'Consejo de Estado',
    title: 'Pol\u00edtica de drogas como asunto de salud p\u00fablica \u2014 201800444',
  },
];

const toc = [
  { id: 'overview', label: 'Resumen' },
  { id: 'explore',  label: 'Explora' },
  { id: 'research', label: 'Investigación' },
  { id: 'advocacy', label: 'Litigio' },
  { id: 'teaching', label: 'Docencia' },
  { id: 'writing',  label: 'Escritura' },
  { id: 'contact',  label: 'Contacto' },
];

const teachingItems = [
  {
    meta: 'Cl\u00ednica Jur\u00eddica UIS',
    title: 'Coordinador fundador \u2014 Cl\u00ednica de Litigio Estrat\u00e9gico Carlos Gaviria D\u00edaz',
  },
  {
    meta: 'Maestr\u00eda UIS',
    title: 'Metodolog\u00edas de Investigaci\u00f3n en Derechos Humanos',
  },
  {
    meta: 'Universidad de los Andes',
    title: 'Asistente docente e investigador \u00b7 CIJUS',
  },
];
---
<BaseLayout
  title={profile.name}
  description={`${profile.name} — Estudiante doctoral en Ciencia Política en UIC, becario Fulbright–MinCiencias. Investigación sobre justicia transicional, cortes y movilización de derechos.`}
  lang={lang}
  current="home"
  toc={toc}
>
  <!-- 1. Hero -->
  <div id="overview">
    <HomeHero lang={lang} />
  </div>

  <!-- 2. Lo que hago (Promise) -->
  <Promise lang={lang} />

  <!-- 3. Bio corta -->
  <section class="section">
    <div class="section-inner" style="max-width: var(--measure);">
      <p class="lead" set:html={bio.short[lang]} />
    </div>
  </section>

  <!-- 4. Explorar el sitio — grid de atajos -->
  <section class="section" id="explore">
    <div class="section-inner">
      <div class="section-eyebrow reveal">Explora el sitio</div>
      <h2 class="section-title reveal" style="margin-bottom: var(--sp-5);">¿Por dónde seguir?</h2>
      <div class="explore-grid reveal-stagger">
        <a class="explore-card" href={`/${lang}/research/`}>
          <div class="explore-eyebrow">01</div>
          <h3>Investigación y Publicaciones</h3>
          <p>Artículos arbitrados, capítulos de libro, reportes de política y trabajos en curso.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/incidencia/`}>
          <div class="explore-eyebrow">02</div>
          <h3>Litigio</h3>
          <p>Más de 30 amicus curiae e intervenciones ante altas cortes colombianas, el Sistema Interamericano y la CPI.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/teaching/`}>
          <div class="explore-eyebrow">03</div>
          <h3>Docencia</h3>
          <p>Teoría Constitucional, Metodologías de Investigación y educación jurídica clínica en UIS y Los Andes.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/writing/`}>
          <div class="explore-eyebrow">04</div>
          <h3>Opinión y Medios</h3>
          <p>Columnas, apariciones en prensa, radio y pódcast sobre justicia transicional y derechos humanos.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/cv/`}>
          <div class="explore-eyebrow">05</div>
          <h3>Hoja de vida</h3>
          <p>Formación, becas, experiencia de investigación, publicaciones y servicio.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
        <a class="explore-card" href={`/${lang}/contact/`}>
          <div class="explore-eyebrow">06</div>
          <h3>Contacto</h3>
          <p>Colaboraciones, consultorías, peritajes, invitaciones o consultas de prensa.</p>
          <span class="explore-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Tease Investigación -->
  <div id="research">
    <SectionTease
      lang={lang}
      eyebrow={t.home.researchEyebrow[lang]}
      title="Art\u00edculos arbitrados, reportes de pol\u00edtica y bases de datos de investigaci\u00f3n."
      body={t.home.researchBody[lang]}
      href={`/${lang}/research/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={researchItems}
      variant="subtle"
    />
  </div>

  <!-- 6. Tease Incidencia -->
  <div id="advocacy">
    <SectionTease
      lang={lang}
      eyebrow={t.home.advocacyEyebrow[lang]}
      title="M\u00e1s de treinta amicus curiae e intervenciones constitucionales."
      body={t.home.advocacyBody[lang]}
      href={`/${lang}/incidencia/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={advocacyItems}
      variant="light"
    />
  </div>

  <!-- 7. Tease Docencia -->
  <div id="teaching">
    <SectionTease
      lang={lang}
      eyebrow={t.home.teachingEyebrow[lang]}
      title="Docencia cl\u00ednica, constitucional y metodol\u00f3gica."
      body={t.home.teachingBody[lang]}
      href={`/${lang}/teaching/`}
      ctaLabel={t.labels.viewFull[lang]}
      items={teachingItems}
      variant="subtle"
    />
  </div>

  <!-- 8. Textos y Boletín (sección unificada) -->
  <section class="section full-bleed" id="writing">
    <div class="section-inner">
      <div class="section-eyebrow">{t.nav.writing[lang]}</div>
      <h2 class="section-title">{profile.newsletter.publicationName[lang]}</h2>
      {latestPosts.length > 0 ? (
        <ul class="post-list home-post-list">
          {latestPosts.map((p) => (
            <li>
              <time datetime={p.date.toISOString()}>
                {p.date.toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3>
                <a href={p.href} {...(p.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  {p.title}
                </a>
              </h3>
              {p.summary && <p class="muted">{p.summary}</p>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="muted">{t.labels.noPostsYet[lang]}</p>
      )}
      <p style="margin-top: var(--sp-5);">
        <a class="btn btn-outline" href={`/${lang}/writing/`}>Todos los textos y prensa &rarr;</a>
      </p>
      <div style="margin-top: var(--sp-8); padding-top: var(--sp-6); border-top: 1px solid var(--rule);">
        <NewsletterEmbed lang={lang} />
      </div>
    </div>
  </section>

  <!-- 9. Redes sociales -->
  <section class="section">
    <div class="section-inner">
      <div class="section-eyebrow">Enc\u00faentrame en l\u00ednea</div>
      <SocialRow lang={lang} />
    </div>
  </section>

  <!-- 10. Contacto -->
  <ContactInline lang={lang} id="contact" />
</BaseLayout>

<style>
  .cta-strip { padding-block: var(--sp-2); }
  .cta-strip-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }
  .home-post-list {
    margin-top: var(--sp-5);
  }
</style>
