---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { profile } from '~/data/profile';
import type { Lang } from '~/data/i18n';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  current?: string;
  wide?: boolean;
}
const { title, description, lang, current, wide = false } = Astro.props;
const pageTitle = title === profile.name ? title : `${title} — ${profile.shortName}`;
const desc = description || `${profile.name} — ${profile.title[lang]}, ${profile.affiliation[lang]}. ${profile.fellowship}.`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang={lang === 'en' ? 'en-US' : 'es-ES'}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_ES'} />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${profile.shortName} — Blog`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,350;0,9..144,400;0,9..144,450;0,9..144,500;1,9..144,400&family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;450;500;600;700&display=swap"
    rel="stylesheet"
  />
  <!-- Alternate hreflang -->
  <link rel="alternate" hreflang="en" href={`https://josejans.com${Astro.url.pathname.replace(`/${lang}/`, '/en/')}`} />
  <link rel="alternate" hreflang="es" href={`https://josejans.com${Astro.url.pathname.replace(`/${lang}/`, '/es/')}`} />
  <link rel="alternate" hreflang="x-default" href={`https://josejans.com${Astro.url.pathname.replace(`/${lang}/`, '/en/')}`} />
</head>
<body>
  <Header lang={lang} current={current} />
  <main class={wide ? 'wide' : ''}>
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
