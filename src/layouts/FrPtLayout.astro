---
/**
 * Lightweight layout for French (FR) and Portuguese (PT) pages.
 * These languages have only Home + About; all other nav links route to /en/.
 * Avoids extending the typed Lang union — uses standalone typed approach.
 */
import '~/styles/global.css';
import { profile } from '~/data/profile';

interface Props {
  title: string;
  description: string;
  lang: 'fr' | 'pt';
  current?: 'home' | 'about';
}
const { title, description, lang, current } = Astro.props;
const pageTitle = `${title} — ${profile.shortName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const htmlLang = lang === 'fr' ? 'fr-FR' : 'pt-BR';
const ogLocale = lang === 'fr' ? 'fr_FR' : 'pt_BR';

// Nav labels
const nav = lang === 'fr'
  ? { home: 'Accueil', about: 'À propos', research: 'Recherche', advocacy: 'Plaidoyer', teaching: 'Enseignement', writing: 'Opinion', contact: 'Contact' }
  : { home: 'Início', about: 'Sobre', research: 'Pesquisa', advocacy: 'Advocacia', teaching: 'Ensino', writing: 'Opinião', contact: 'Contato' };

// Nav items: home + about go to /fr/ or /pt/; rest go to /en/
const navItems = [
  { href: `/${lang}/about/`, label: nav.about, key: 'about' },
  { href: '/en/research/', label: nav.research, key: 'research' },
  { href: '/en/advocacy/', label: nav.advocacy, key: 'advocacy' },
  { href: '/en/teaching/', label: nav.teaching, key: 'teaching' },
  { href: '/en/writing/', label: nav.writing, key: 'writing' },
  { href: '/en/contact/', label: nav.contact, key: 'contact' },
];

const year = new Date().getFullYear();
const followLabel = lang === 'fr' ? 'Suivez mes travaux' : 'Acompanhe meu trabalho';
---
<!doctype html>
<html lang={htmlLang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={ogLocale} />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${profile.shortName} — Blog`} />
  <link rel="stylesheet" href="https://use.typekit.net/ydc1ssn.css" />
  <link rel="alternate" hreflang="en" href={`https://josejans.com/en/`} />
  <link rel="alternate" hreflang="es" href={`https://josejans.com/es/`} />
  <link rel="alternate" hreflang="fr" href={`https://josejans.com/fr/`} />
  <link rel="alternate" hreflang="pt" href={`https://josejans.com/pt/`} />
  <link rel="alternate" hreflang="x-default" href={`https://josejans.com/en/`} />
</head>
<body>
  <!-- Header (simplified — all non-home/about nav links go to /en/) -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href={`/${lang}/`} class="site-home-link" aria-label="Accueil / Início">
        <svg class="site-home-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 9.5L10 3l7 6.5V17a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
          <path d="M7 18v-7h6v7"/>
        </svg>
        {profile.shortName}
      </a>

      <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu" type="button">
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>

      <nav class="site-nav" id="site-nav" aria-label="Primary">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={current === item.key ? 'active' : ''}
            title={item.key !== 'about' ? (lang === 'fr' ? 'Version anglaise' : 'Versão em inglês') : undefined}
          >
            {item.label}
            {item.key !== 'about' && <sup style="font-size:0.6em; opacity:0.5">EN</sup>}
          </a>
        ))}

        <!-- Language toggles -->
        <div class="lang-toggles" aria-label="Language">
          <a href="/en/" class="lang-btn">EN</a>
          <a href="/es/" class="lang-btn">ES</a>
          <a href="/fr/" class={`lang-btn ${lang === 'fr' ? 'active' : ''}`} aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
          <a href="/pt/" class={`lang-btn ${lang === 'pt' ? 'active' : ''}`} aria-current={lang === 'pt' ? 'true' : undefined}>PT</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer — uses same classes as Footer.astro for consistent styling -->
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="footer-social-block">
        <div class="footer-social-label">{followLabel}</div>
        <div class="footer-social">
          <a class="footer-social-icon" href={`mailto:${profile.email}`} aria-label="Email" title="Email">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg></span>
          </a>
          <a class="footer-social-icon" href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></span>
          </a>
          <a class="footer-social-icon" href={profile.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" title="X / Twitter">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.7 5.5 4.3 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></span>
          </a>
          <a class="footer-social-icon" href={profile.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></span>
          </a>
          {profile.social.github && (
            <a class="footer-social-icon" href={profile.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
              <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg></span>
            </a>
          )}
          <a class="footer-social-icon" href={profile.social.uic} target="_blank" rel="noopener noreferrer" aria-label="UIC Profile" title="UIC Profile">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="10" width="18" height="11" rx="1"/><path d="M7 10V7a5 5 0 0110 0v3"/><circle cx="12" cy="16" r="2"/></svg></span>
          </a>
          {profile.social.scholar && (
            <a class="footer-social-icon" href={profile.social.scholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar" title="Google Scholar">
              <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M6 11v5c0 2.76 2.69 5 6 5s6-2.24 6-5v-5"/><path d="M22 8v4"/></svg></span>
            </a>
          )}
          {profile.social.substack && (
            <a class="footer-social-icon" href={profile.social.substack} target="_blank" rel="noopener noreferrer" aria-label="Substack" title="Substack">
              <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 5h18M3 10h18M3 19l9-9 9 9V10H3z"/></svg></span>
            </a>
          )}
          <a class="footer-social-icon" href="/cv.pdf" target="_blank" rel="noopener" aria-label="CV (PDF)" title="CV (PDF)">
            <span class="icon-lg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></span>
          </a>
        </div>
      </div>
      <div class="footer-meta">
        &copy; {year} {profile.name} &middot;
        <a href="/en/">English</a> &middot;
        <a href="/es/">Español</a>
      </div>
    </div>
  </footer>

  <!-- Mobile nav toggle script -->
  <script>
    const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
    const nav = document.querySelector<HTMLElement>('#site-nav');
    const header = document.querySelector<HTMLElement>('.site-header');
    if (toggle && nav && header) {
      toggle.addEventListener('click', () => {
        const open = header.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      nav.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          header.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>

  <!-- Scroll-reveal -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal, .reveal-fade').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
